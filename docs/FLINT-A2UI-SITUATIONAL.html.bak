</div>
<div class="ag-snd-m" style="margin-left:48px;margin-bottom:12px;">
<div class="ag-snd-mi">📊<div style="font-size:11px;margin-top:4px;">Dashboard</div></div>
<div class="ag-snd-mi">📄<div style="font-size:11px;margin-top:4px;">JSON</div></div>
<div class="ag-snd-mi">🎨<div style="font-size:11px;margin-top:4px;">Preview</div></div>
</div>
<div class="ag-typing" style="margin-left:48px;">
<span style="width:8px;height:8px;border-radius:50%;background:var(--cy);display:inline-block;"></span>
<span style="width:8px;height:8px;border-radius:50%;background:var(--cy);display:inline-block;"></span>
<span style="width:8px;height:8px;border-radius:50%;background:var(--cy);display:inline-block;"></span>
<span>Agent is thinking...</span>
</div>
</div>
