<!-- Tabs Section -->
<section id="tabs" class="sec">
<div class="sec-h"><div class="icon">📑</div><h3>Tabbed Interfaces</h3><span class="tag">Navigation</span></div>

<div class="comp-grid">
<div class="comp-item" style="grid-column:1/-1;">
<h4>📑 Complex Tabbed Panel</h4>
<div class="demo">
<div class="demo-label">Tabs with Content</div>
<div x-data="{tab:'overview'}">
<div class="tbs">
<button class="tb" :class="tab=='overview'?'on':''" @click="tab='overview'">Overview</button>
<button class="tb" :class="tab=='analytics'?'on':''" @click="tab='analytics'">Analytics</button>
<button class="tb" :class="tab=='settings'?'on':''" @click="tab='settings'">Settings</button>
<button class="tb" :class="tab=='logs'?'on':''" @click="tab='logs'">Logs</button>
</div>
<div class="tbc">
<div x-show="tab=='overview'" x-transition>
<div class="grid grid-3" style="gap:12px;margin-bottom:16px;">
<div class="mc"><div class="mc-v">12,847</div><div class="mc-l">Users</div><div class="mc-d up">↑ 12.5%</div></div>
<div class="mc"><div class="mc-v">$84.2K</div><div class="mc-l">Revenue</div><div class="mc-d up">↑ 8.3%</div></div>
<div class="mc"><div class="mc-v">99.9%</div><div class="mc-l">Uptime</div><div class="mc-d up">↑ 0.1%</div></div>
</div>
<div class="card"><div class="card-h">Recent Activity</div><div class="card-d">Last 24 hours of system activity and user interactions.</div>
<div class="tl">
<div class="tl-i"><div class="tl-d"></div><div class="tl-c">New user registered</div><div class="tl-t">2 min ago</div><div class="tl-x">Alice Chen joined the platform</div></div>
<div class="tl-i"><div class="tl-d"></div><div class="tl-c">Component updated</div><div class="tl-t">15 min ago</div><div class="tl-x">Button variant "ghost" added</div></div>
<div class="tl-i"><div class="tl-d"></div><div class="tl-c">Deployment completed</div><div class="tl-t">1 hour ago</div><div class="tl-x">v2.1.0 deployed to production</div></div>
</div>
</div>
</div>
<div x-show="tab=='analytics'" x-transition style="display:none;">
<div class="card"><div class="card-h">Traffic Analytics</div><div class="card-d">Page views and user sessions over the last 30 days.</div>
<div style="height:200px;background:var(--s3);border-radius:8px;display:flex;align-items:end;gap:4px;padding:16px;">
<div style="flex:1;background:var(--em);border-radius:2px;height:40%;opacity:0.7;"></div>
<div style="flex:1;background:var(--em);border-radius:2px;height:55%;opacity:0.8;"></div>
<div style="flex:1;background:var(--em);border-radius:2px;height:45%;opacity:0.7;"></div>
<div style="flex:1;background:var(--em);border-radius:2px;height:70%;opacity:0.9;"></div>
<div style="flex:1;background:var(--em);border-radius:2px;height:60%;opacity:0.8;"></div>
<div style="flex:1;background:var(--em);border-radius:2px;height:85%;opacity:1;"></div>
<div style="flex:1;background:var(--cy);border-radius:2px;height:75%;opacity:0.9;"></div>
</div>
</div>
</div>
<div x-show="tab=='settings'" x-transition style="display:none;">
<div class="fg"><label class="lbl">Site Name</label><input type="text" class="inp" value="Flint Platform"></div>
<div class="fg"><label class="lbl">Timezone</label><select class="sel"><option>UTC</option><option>EST</option><option>PST</option></select></div>
<div class="fg" x-data="{on:true}"><label class="lbl">Maintenance Mode</label><div class="sw" @click="on=!on"><div class="sw-i" :class="on?'on':''"></div><span class="sw-l" x-text="on?'Enabled':'Disabled'"></span></div></div>
<div style="display:flex;gap:8px;margin-top:16px;"><button class="btn btn-p">Save Settings</button><button class="btn btn-ghost">Reset</button></div>
</div>
<div x-show="tab=='logs'" x-transition style="display:none;">
<div style="background:var(--s3);border:1px solid var(--s4);border-radius:8px;padding:16px;font-family:var(--fm);font-size:12px;max-height:300px;overflow:auto;">
<div style="margin-bottom:4px;"><span style="color:var(--gr);">[INFO]</span> <span style="color:var(--txtd);">2024-03-15 10:23:45</span> <span style="color:var(--txtm);">Server started on port 3000</span></div>
<div style="margin-bottom:4px;"><span style="color:var(--cy);">[DEBUG]</span> <span style="color:var(--txtd);">2024-03-15 10:23:46</span> <span style="color:var(--txtm);">Database connection established</span></div>
<div style="margin-bottom:4px;"><span style="color:var(--yl);">[WARN]</span> <span style="color:var(--txtd);">2024-03-15 10:24:12</span> <span style="color:var(--txtm);">Slow query detected: 340ms</span></div>
<div style="margin-bottom:4px;"><span style="color:var(--gr);">[INFO]</span> <span style="color:var(--txtd);">2024-03-15 10:25:01</span> <span style="color:var(--txtm);">User login: alice@example.com</span></div>
<div style="margin-bottom:4px;"><span style="color:var(--rd);">[ERROR]</span> <span style="color:var(--txtd);">2024-03-15 10:26:33</span> <span style="color:var(--txtm);">Failed to connect to external API</span></div>
</div>
</div>
</div>
</div>
<div class="demo-code">{"type":"tabbed_panel","tabs":["Overview","Analytics","Settings","Logs"],"content_type":"dynamic","hx_get":"/api/tab/{id}"}</div>
</div>
</div>
</div>
</section>

