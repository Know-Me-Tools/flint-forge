<div class="demo">
<div class="demo-label">Visual</div>
<div class="fg" x-data="{tags:['Design','UI','A2UI'], newTag:''}">
<label class="lbl">Tags</label>
<div class="tgi">
<template x-for="tag in tags" :key="tag">
<div class="tgi-t"><span x-text="tag"></span><button @click="tags = tags.filter(t => t !== tag)">×</button></div>
</template>
<input type="text" class="inp" style="border:none;padding:4px 8px;flex:1;min-width:80px;" placeholder="Add tag..." x-model="newTag" @keydown.enter="if(newTag.trim()){tags.push(newTag.trim());newTag=''}"
@keydown.backspace="if(!newTag && tags.length){tags.pop()}">
</div>
</div>
</div>
<div class="demo-code">{"type":"tag_input","label":"Tags","value":["Design","UI","A2UI"],"x_model":"tags"}</div>
</div>

