<!DOCTYPE html>
<html lang="en"><head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Flint A2UI Registry Specification</title>
<script src="https://unpkg.com/htmx.org@2.0.4"></script>
<script defer src="https://cdn.jsdelivr.net/npm/alpinejs@3.x.x/dist/cdn.min.js"></script>
<link href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@400;500;600;700&family=Inter:wght@400;500;600&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet">
<style>
:root{--bg:#0B0F14;--s1:#131A22;--s2:#1A232E;--s3:#0E141B;--s4:#202B38;--s5:#2A3542;
--txt:#E8EDF3;--txtm:#B4BECB;--txtd:#97A1AE;--em:#FF6A3D;--emd:#E04E28;--cy:#34CFE6;
--gr:#4FD18B;--yl:#F4B942;--rd:#F05D5D;--fd:'Space Grotesk';--fb:'Inter';--fm:'JetBrains Mono'}
*{box-sizing:border-box;margin:0;padding:0}
html{scroll-behavior:smooth}
body{background:var(--bg);color:var(--txt);font-family:var(--fb);font-size:14px;line-height:1.6;overflow-x:hidden}

h1,h2,h3,h4{font-family:var(--fd);font-weight:600;letter-spacing:-0.02em}
h1{font-size:2.8rem;margin-bottom:1rem}h2{font-size:1.8rem;margin:2rem 0 1rem}h3{font-size:1.3rem;margin:1.5rem 0 0.8rem}
h4{font-size:1.1rem;margin:1rem 0 0.5rem}
p{margin-bottom:1rem;color:var(--txtm)}
code{font-family:var(--fm);font-size:12px;background:var(--s3);padding:2px 6px;border-radius:4px;color:var(--cy)}
pre{background:var(--s3);border:1px solid var(--s4);border-radius:8px;padding:16px;overflow-x:auto;font-family:var(--fm);font-size:12px}
pre code{background:none;padding:0}

.container{max-width:1400px;margin:0 auto;padding:0 24px}
.grid{display:grid;gap:24px}
.grid-2{grid-template-columns:repeat(2,1fr)}
.grid-3{grid-template-columns:repeat(3,1fr)}
.grid-4{grid-template-columns:repeat(4,1fr)}
@media(max-width:900px){.grid-2,.grid-3,.grid-4{grid-template-columns:1fr}}

.hero{background:var(--s1);border-bottom:1px solid var(--s4);padding:60px 0;text-align:center}
.hero-b{display:inline-block;background:rgba(255,106,61,0.15);color:var(--em);padding:6px 16px;border-radius:20px;font-size:12px;font-weight:600;text-transform:uppercase;letter-spacing:1px;margin-bottom:16px}
.hero p{max-width:700px;margin:0 auto 24px;color:var(--txtd)}

.sec{background:var(--s1);border:1px solid var(--s4);border-radius:12px;padding:24px;margin-bottom:24px}
.sec-h{display:flex;align-items:center;gap:12px;margin-bottom:16px}
.sec-h .icon{width:36px;height:36px;background:var(--s3);border-radius:8px;display:flex;align-items:center;justify-content:center;font-size:18px}
.sec-h h3{margin:0}
.sec-h .tag{font-size:11px;background:var(--s3);color:var(--txtd);padding:2px 8px;border-radius:4px;border:1px solid var(--s4)}

.demo{background:var(--bg);border:1px solid var(--s4);border-radius:8px;padding:20px;margin:16px 0}
.demo-label{font-size:11px;text-transform:uppercase;letter-spacing:1px;color:var(--txtd);margin-bottom:8px;font-weight:600}

.btn{display:inline-flex;align-items:center;gap:8px;padding:8px 16px;border-radius:8px;border:none;font-size:13px;font-weight:500;cursor:pointer;transition:all 0.2s;text-decoration:none}
.btn-p{background:var(--em);color:#fff}
.btn-p:hover{background:var(--emd);transform:translateY(-1px)}
.btn-s{background:var(--s3);color:var(--txt);border:1px solid var(--s4)}
.btn-s:hover{border-color:var(--cy)}
.btn-g{background:var(--s3);color:var(--gr);border:1px solid rgba(79,209,139,0.3)}
.btn-g:hover{background:rgba(79,209,139,0.1)}
.btn-r{background:var(--s3);color:var(--rd);border:1px solid rgba(240,93,93,0.3)}
.btn-ghost{background:transparent;color:var(--txtm);border:1px solid var(--s4)}
.btn-ghost:hover{color:var(--txt);border-color:var(--cy)}
.btn-sm{padding:4px 10px;font-size:12px}
.btn-lg{padding:12px 24px;font-size:14px}
.btn-i{padding:8px}

.inp{width:100%;background:var(--bg);border:1px solid var(--s4);border-radius:8px;padding:10px 14px;color:var(--txt);font-size:13px;transition:all 0.2s}
.inp:focus{outline:none;border-color:var(--cy);box-shadow:0 0 0 3px rgba(52,207,230,0.1)}
.inp::placeholder{color:var(--txtd)}
.lbl{display:block;font-size:12px;font-weight:500;color:var(--txtm);margin-bottom:6px;text-transform:uppercase;letter-spacing:0.5px}
.fg{margin-bottom:16px}
.sel{width:100%;background:var(--bg);border:1px solid var(--s4);border-radius:8px;padding:10px 14px;color:var(--txt);font-size:13px;cursor:pointer}
.sel:focus{outline:none;border-color:var(--cy)}
.tx{width:100%;min-height:100px;background:var(--bg);border:1px solid var(--s4);border-radius:8px;padding:10px 14px;color:var(--txt);font-size:13px;resize:vertical}
.tx:focus{outline:none;border-color:var(--cy)}
.chk,.rd{display:flex;align-items:center;gap:8px;cursor:pointer;margin:8px 0;font-size:13px;color:var(--txtm)}
.chk input,.rd input{accent-color:var(--em)}

.tbl{width:100%;border-collapse:collapse;font-size:13px}
.tbl th{text-align:left;padding:10px 12px;background:var(--s3);color:var(--txtd);font-weight:600;font-size:11px;text-transform:uppercase;letter-spacing:0.5px;border-bottom:1px solid var(--s4)}
.tbl td{padding:10px 12px;border-bottom:1px solid var(--s4);color:var(--txtm)}
.tbl tr:hover td{background:rgba(52,207,230,0.05)}
.tbl tr:last-child td{border-bottom:none}

.bd-g{display:inline-block;padding:2px 8px;border-radius:4px;font-size:11px;font-weight:600;background:rgba(79,209,139,0.15);color:var(--gr)}
.bd-y{display:inline-block;padding:2px 8px;border-radius:4px;font-size:11px;font-weight:600;background:rgba(244,185,66,0.15);color:var(--yl)}
.bd-r{display:inline-block;padding:2px 8px;border-radius:4px;font-size:11px;font-weight:600;background:rgba(240,93,93,0.15);color:var(--rd)}
.bd-e{display:inline-block;padding:2px 8px;border-radius:4px;font-size:11px;font-weight:600;background:rgba(255,106,61,0.15);color:var(--em)}
.bd-c{display:inline-block;padding:2px 8px;border-radius:4px;font-size:11px;font-weight:600;background:rgba(52,207,230,0.15);color:var(--cy)}
.bd-d{display:inline-block;padding:2px 8px;border-radius:4px;font-size:11px;font-weight:600;background:var(--s3);color:var(--txtd)}

.card{background:var(--s2);border:1px solid var(--s4);border-radius:10px;padding:20px;transition:all 0.2s}
.card:hover{border-color:var(--cy);transform:translateY(-2px)}
.card-h{font-size:14px;font-weight:600;margin-bottom:8px;color:var(--txt)}
.card-d{font-size:13px;color:var(--txtd);margin-bottom:12px}

.tbs{display:flex;border-bottom:1px solid var(--s4);gap:4px;margin-bottom:16px}
.tb{padding:10px 16px;border:none;background:none;color:var(--txtd);font-size:13px;cursor:pointer;border-bottom:2px solid transparent;transition:all 0.2s}
.tb.on{color:var(--cy);border-bottom-color:var(--cy)}
.tb:hover{color:var(--txt)}

.acc{border:1px solid var(--s4);border-radius:8px;margin-bottom:8px;overflow:hidden}
.acc-h{display:flex;align-items:center;justify-content:space-between;padding:12px 16px;background:var(--s2);cursor:pointer;font-weight:500;font-size:13px}
.acc-h:hover{background:var(--s3)}
.acc-b{padding:12px 16px;background:var(--bg);border-top:1px solid var(--s4);font-size:13px;color:var(--txtm)}

.mod-o{position:fixed;inset:0;background:rgba(0,0,0,0.7);display:flex;align-items:center;justify-content:center;z-index:1000;backdrop-filter:blur(4px)}
.mod-c{background:var(--s2);border:1px solid var(--s4);border-radius:12px;max-width:600px;width:90%;max-height:80vh;overflow:auto}
.mod-h{display:flex;align-items:center;justify-content:space-between;padding:16px 20px;border-bottom:1px solid var(--s4)}
.mod-h h4{margin:0}
.mod-b{padding:20px}
.mod-f{display:flex;justify-content:flex-end;gap:8px;padding:16px 20px;border-top:1px solid var(--s4)}

.drw{position:fixed;top:0;right:0;width:400px;max-width:90vw;height:100%;background:var(--s2);border-left:1px solid var(--s4);z-index:1001;display:flex;flex-direction:column}
.drw-h{display:flex;align-items:center;justify-content:space-between;padding:16px 20px;border-bottom:1px solid var(--s4)}
.drw-b{flex:1;overflow:auto;padding:20px}
.drw-f{padding:16px 20px;border-top:1px solid var(--s4)}

.tbar{display:flex;align-items:center;gap:16px;padding:12px 24px;background:var(--s1);border-bottom:1px solid var(--s4);position:sticky;top:0;z-index:100}
.tbar-l{font-family:var(--fd);font-weight:700;font-size:18px;color:var(--em)}
.tbar-n{display:flex;gap:4px}
.tbar-n a{padding:6px 12px;border-radius:6px;color:var(--txtm);text-decoration:none;font-size:13px;transition:all 0.2s}
.tbar-n a:hover,.tbar-n a.on{background:var(--s3);color:var(--txt)}
.snav{width:260px;background:var(--s1);border-right:1px solid var(--s4);min-height:100vh;position:fixed;top:0;left:0;overflow-y:auto;z-index:99}
.snav-h{padding:16px 20px;border-bottom:1px solid var(--s4);display:flex;align-items:center;gap:12px}
.snav-l{display:flex;align-items:center;gap:10px;font-family:var(--fd);font-weight:700;font-size:16px}
.snav-li{width:32px;height:32px;background:var(--em);border-radius:8px;display:flex;align-items:center;justify-content:center;color:#fff;font-weight:700}
.snav-i{display:flex;align-items:center;gap:10px;padding:10px 20px;color:var(--txtm);text-decoration:none;font-size:13px;transition:all 0.2s;border-left:3px solid transparent}
.snav-i:hover{background:var(--s2);color:var(--txt)}
.snav-i.on{border-left-color:var(--em);background:var(--s2);color:var(--txt)}

.av{width:36px;height:36px;border-radius:50%;background:var(--s3);display:flex;align-items:center;justify-content:center;font-size:14px;font-weight:600;color:var(--cy);border:2px solid var(--s4)}
.av-sm{width:28px;height:28px;font-size:12px}
.av-lg{width:48px;height:48px;font-size:16px}
.av-g{border-radius:8px}

.pb{height:6px;background:var(--s3);border-radius:3px;overflow:hidden}
.pb-b{height:100%;background:var(--em);border-radius:3px;transition:width 0.5s ease}
.pb-g .pb-b{background:var(--gr)}
.pb-c .pb-b{background:var(--cy)}
.pf{display:flex;align-items:center;gap:12px;margin:8px 0}
.pf-l{font-size:12px;color:var(--txtd);min-width:80px}
.pf-b{flex:1}
.pf-v{font-size:12px;color:var(--txtm);min-width:40px;text-align:right}

.chat{display:flex;flex-direction:column;gap:16px;max-height:500px;overflow-y:auto;padding:16px;background:var(--bg);border-radius:8px}
.chat-m{display:flex;gap:12px;align-items:flex-start}
.chat-m.own{flex-direction:row-reverse}
.chat-b{padding:10px 14px;border-radius:12px;max-width:70%;font-size:13px}
.chat-m:not(.own) .chat-b{background:var(--s2);border:1px solid var(--s4);color:var(--txtm)}
.chat-m.own .chat-b{background:var(--em);color:#fff}
.chat-t{font-size:11px;color:var(--txtd);margin-top:4px}

.tl{position:relative;padding-left:24px}
.tl::before{content:'';position:absolute;left:7px;top:8px;bottom:8px;width:2px;background:var(--s4)}
.tl-i{position:relative;margin-bottom:20px}
.tl-d{position:absolute;left:-24px;top:4px;width:16px;height:16px;border-radius:50%;background:var(--s3);border:2px solid var(--cy);z-index:1}
.tl-c{font-size:12px;font-weight:600;color:var(--txt);margin-bottom:4px}
.tl-t{font-size:11px;color:var(--txtd);margin-bottom:4px}
.tl-x{font-size:13px;color:var(--txtm)}

.kb{display:flex;gap:16px;overflow-x:auto;padding-bottom:8px}
.kc{min-width:280px;background:var(--s2);border:1px solid var(--s4);border-radius:10px;padding:16px}
.kc-h{display:flex;align-items:center;justify-content:space-between;margin-bottom:12px}
.kc-t{font-size:13px;font-weight:600}
.kc-n{font-size:11px;background:var(--s3);padding:2px 8px;border-radius:4px;color:var(--txtd)}
.kcd{background:var(--bg);border:1px solid var(--s4);border-radius:8px;padding:12px;margin-bottom:8px;cursor:grab;transition:all 0.2s}
.kcd:hover{border-color:var(--cy)}
.kcd-h{font-size:13px;font-weight:500;margin-bottom:4px}
.kcd-t{font-size:11px;color:var(--txtd);margin-bottom:8px}
.kcd-b{display:flex;gap:6px;flex-wrap:wrap}

.mc{background:var(--s2);border:1px solid var(--s4);border-radius:10px;padding:20px;transition:all 0.2s}
.mc:hover{border-color:var(--cy)}
.mc-v{font-size:28px;font-weight:700;font-family:var(--fd);color:var(--txt);margin-bottom:4px}
.mc-l{font-size:12px;color:var(--txtd);text-transform:uppercase;letter-spacing:0.5px;margin-bottom:8px}
.mc-d{display:flex;align-items:center;gap:6px;font-size:13px}
.mc-d.up{color:var(--gr)}.mc-d.down{color:var(--rd)}
.mv{display:flex;align-items:center;gap:12px;padding:16px;background:var(--s2);border:1px solid var(--s4);border-radius:10px}
.mv-i{width:40px;height:40px;border-radius:10px;background:var(--s3);display:flex;align-items:center;justify-content:center;font-size:20px}
.mv-c{flex:1}
.mv-v{font-size:18px;font-weight:700;font-family:var(--fd)}
.mv-l{font-size:12px;color:var(--txtd)}

.stp{display:flex;align-items:center;gap:8px;margin:24px 0}
.st{display:flex;align-items:center;gap:8px}
.stc{width:32px;height:32px;border-radius:50%;display:flex;align-items:center;justify-content:center;font-size:13px;font-weight:600;background:var(--s3);border:2px solid var(--s4);color:var(--txtd)}
.stc.on{background:var(--em);border-color:var(--em);color:#fff}
.stc.done{background:var(--gr);border-color:var(--gr);color:#fff}
.stl{flex:1;height:2px;background:var(--s4);min-width:40px}
.stl.on{background:var(--em)}
.stt{font-size:12px;color:var(--txtd);margin-top:4px;white-space:nowrap}

.pg{display:flex;gap:4px;justify-content:center;align-items:center}
.pg-b{padding:6px 12px;border:1px solid var(--s4);background:var(--s2);color:var(--txtm);border-radius:6px;cursor:pointer;font-size:13px;transition:all 0.2s}
.pg-b:hover{border-color:var(--cy);color:var(--txt)}
.pg-b.on{background:var(--em);border-color:var(--em);color:#fff}
.pg-b:disabled{opacity:0.4;cursor:not-allowed}

.fb{display:flex;gap:12px;align-items:center;flex-wrap:wrap;padding:16px;background:var(--s2);border:1px solid var(--s4);border-radius:10px;margin-bottom:16px}
.ft{flex:1;min-width:200px;position:relative}
.ft-i{width:100%;padding:10px 14px 10px 36px;background:var(--bg);border:1px solid var(--s4);border-radius:8px;color:var(--txt);font-size:13px}
.ft-i:focus{outline:none;border-color:var(--cy)}
.ft::before{content:'🔍';position:absolute;left:12px;top:50%;transform:translateY(-50%);font-size:12px;opacity:0.6}

.tt-c{position:fixed;bottom:24px;right:24px;z-index:1002;display:flex;flex-direction:column;gap:8px}
.tt{background:var(--s2);border:1px solid var(--s4);border-radius:10px;padding:14px 18px;display:flex;align-items:center;gap:12px;box-shadow:0 8px 32px rgba(0,0,0,0.4);min-width:300px;animation:slideIn 0.3s ease}
.tt-g{border-left:3px solid var(--gr)}.tt-r{border-left:3px solid var(--rd)}.tt-y{border-left:3px solid var(--yl)}
.tt-h{font-weight:600;font-size:13px}.tt-b{font-size:12px;color:var(--txtd)}
@keyframes slideIn{from{transform:translateX(100%);opacity:0}to{transform:translateX(0);opacity:1}}

.cp-o{position:fixed;inset:0;background:rgba(0,0,0,0.7);z-index:1003;display:flex;align-items:start;justify-content:center;padding-top:120px;backdrop-filter:blur(4px)}
.cp{background:var(--s2);border:1px solid var(--s4);border-radius:12px;width:600px;max-width:90%;overflow:hidden}
.cp-i{padding:16px 20px;border-bottom:1px solid var(--s4);display:flex;align-items:center;gap:12px}
.cp-i input{flex:1;background:none;border:none;color:var(--txt);font-size:16px;outline:none}
.cp-i input::placeholder{color:var(--txtd)}
.cp-l{max-height:400px;overflow-y:auto}
.cp-r{padding:10px 20px;display:flex;align-items:center;gap:12px;cursor:pointer;transition:all 0.15s}
.cp-r:hover{background:var(--s3)}
.cp-r.on{background:var(--s3);border-left:2px solid var(--em)}
.cp-ri{width:32px;height:32px;background:var(--s3);border-radius:6px;display:flex;align-items:center;justify-content:center;font-size:14px}
.cp-rt{flex:1}
.cp-rt h5{font-size:13px;font-weight:500;margin-bottom:2px}
.cp-rt p{font-size:11px;color:var(--txtd)}
.cp-rs{font-size:11px;color:var(--txtd);font-family:var(--fm)}

.htmx-added{animation:fadeIn 0.3s ease}
.htmx-swapping{animation:fadeOut 0.2s ease}
.fade-me-in{animation:fadeIn 0.4s ease}
.slide-me-in{animation:slideIn 0.4s ease}
@keyframes fadeIn{from{opacity:0;transform:translateY(8px)}to{opacity:1;transform:translateY(0)}}
@keyframes fadeOut{from{opacity:1}to{opacity:0}}

[x-cloak]{display:none !important}

.page{display:flex;min-height:100vh}
.page .main{flex:1;padding:24px;min-width:0;margin-left:260px}
@media(max-width:900px){.snav{display:none}.page .main{margin-left:0}}

.svg-d{max-width:100%;margin:24px auto;display:block}
.comp-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(300px,1fr));gap:16px}
.comp-item{background:var(--bg);border:1px solid var(--s4);border-radius:8px;padding:16px}
.comp-item h4{font-size:13px;margin-bottom:12px;color:var(--txtd);text-transform:uppercase;letter-spacing:0.5px}
.demo-code{background:var(--s3);border:1px solid var(--s4);border-radius:6px;padding:12px;margin-top:12px;font-family:var(--fm);font-size:11px;overflow-x:auto;color:var(--txtd)}

/* Switch */
.sw{display:flex;align-items:center;gap:10px;cursor:pointer}
.sw-i{position:relative;width:44px;height:24px;background:var(--s4);border-radius:12px;transition:all 0.2s}
.sw-i.on{background:var(--em)}
.sw-i::after{content:'';position:absolute;top:2px;left:2px;width:20px;height:20px;background:#fff;border-radius:50%;transition:all 0.2s}
.sw-i.on::after{left:22px}
.sw-l{font-size:13px;color:var(--txtm)}

/* Tooltip */
.ttp{position:relative;display:inline-block}
.ttp-b{position:absolute;bottom:100%;left:50%;transform:translateX(-50%);padding:6px 10px;background:var(--s2);border:1px solid var(--s4);border-radius:6px;font-size:11px;white-space:nowrap;opacity:0;visibility:hidden;transition:all 0.2s;margin-bottom:6px;z-index:50}
.ttp:hover .ttp-b{opacity:1;visibility:visible}

/* FAB */
.fab{position:fixed;bottom:24px;right:24px;width:56px;height:56px;border-radius:50%;background:var(--em);color:#fff;border:none;font-size:24px;cursor:pointer;box-shadow:0 4px 16px rgba(255,106,61,0.4);z-index:100;display:flex;align-items:center;justify-content:center;transition:all 0.2s}
.fab:hover{transform:scale(1.1)}

/* Menu dropdown */
.mn{position:relative;display:inline-block}
.mn-c{position:absolute;top:100%;left:0;min-width:200px;background:var(--s2);border:1px solid var(--s4);border-radius:8px;box-shadow:0 8px 32px rgba(0,0,0,0.4);z-index:50;overflow:hidden;margin-top:4px}
.mn-i{padding:10px 14px;font-size:13px;color:var(--txtm);cursor:pointer;transition:all 0.15s;border-bottom:1px solid var(--s4)}
.mn-i:last-child{border-bottom:none}
.mn-i:hover{background:var(--s3);color:var(--txt)}
.mn-i-k{font-size:11px;color:var(--txtd);float:right;font-family:var(--fm)}

/* Context menu */
.ctx-mn{background:var(--s2);border:1px solid var(--s4);border-radius:8px;box-shadow:0 8px 32px rgba(0,0,0,0.4);overflow:hidden;min-width:180px}
.ctx-i{padding:8px 14px;font-size:13px;color:var(--txtm);cursor:pointer;border-bottom:1px solid var(--s4);display:flex;align-items:center;gap:8px;transition:all 0.15s}
.ctx-i:last-child{border-bottom:none}
.ctx-i:hover{background:var(--s3);color:var(--txt)}
.ctx-i-rd{color:var(--rd)}

/* Speed dial */
.sd{position:fixed;bottom:100px;right:24px;display:flex;flex-direction:column;align-items:center;gap:12px;z-index:100}
.sd-a{width:40px;height:40px;border-radius:50%;background:var(--s2);border:1px solid var(--s4);color:var(--txt);display:flex;align-items:center;justify-content:center;font-size:16px;cursor:pointer;transition:all 0.2s;box-shadow:0 2px 8px rgba(0,0,0,0.3)}
.sd-a:hover{background:var(--s3);border-color:var(--cy);transform:scale(1.1)}

/* Split button */
.sb{display:inline-flex;align-items:center}
.sb-m{padding:8px 16px;border-radius:8px 0 0 8px;background:var(--em);color:#fff;border:none;font-size:13px;font-weight:500;cursor:pointer}
.sb-d{padding:8px 10px;border-radius:0 8px 8px 0;background:var(--emd);color:#fff;border:none;font-size:13px;cursor:pointer;border-left:1px solid rgba(0,0,0,0.2)}

/* Range slider */
.rng{width:100%;-webkit-appearance:none;appearance:none;height:6px;background:var(--s4);border-radius:3px;outline:none}
.rng::-webkit-slider-thumb{-webkit-appearance:none;appearance:none;width:18px;height:18px;border-radius:50%;background:var(--cy);cursor:pointer;border:2px solid var(--s2);box-shadow:0 2px 6px rgba(0,0,0,0.3)}

/* Tag input */
.tgi{display:flex;flex-wrap:wrap;gap:6px;padding:6px;background:var(--bg);border:1px solid var(--s4);border-radius:8px;align-items:center}
.tgi-t{display:flex;align-items:center;gap:4px;padding:4px 8px;background:var(--s3);border:1px solid var(--s4);border-radius:4px;font-size:12px;color:var(--txtm)}
.tgi-t button{background:none;border:none;color:var(--txtd);cursor:pointer;font-size:14px;padding:0 2px}
.tgi-t button:hover{color:var(--rd)}

/* Color swatch */
.csw{width:32px;height:32px;border-radius:6px;border:2px solid var(--s4);cursor:pointer;transition:all 0.2s}
.csw:hover{border-color:var(--cy);transform:scale(1.1)}
.csw.on{border-color:var(--em);box-shadow:0 0 0 2px rgba(255,106,61,0.3)}

/* Agent-specific components */
.ag-sug{display:flex;gap:8px;flex-wrap:wrap;margin:8px 0}
.ag-sug-b{padding:6px 12px;background:var(--s3);border:1px solid var(--s4);border-radius:16px;font-size:12px;color:var(--txtm);cursor:pointer;transition:all 0.2s}
.ag-sug-b:hover{border-color:var(--cy);color:var(--txt)}
.ag-sug-b.on{background:rgba(52,207,230,0.15);border-color:var(--cy);color:var(--cy)}

.ag-conf{padding:16px;background:var(--s2);border:1px solid var(--s4);border-radius:10px;margin:8px 0}
.ag-conf-h{display:flex;align-items:center;gap:8px;font-size:13px;font-weight:600;margin-bottom:8px}
.ag-conf-b{font-size:12px;color:var(--txtd)}

.ag-res{border:1px solid var(--s4);border-radius:8px;overflow:hidden;margin:8px 0}
.ag-res-h{padding:10px 14px;background:var(--s3);font-size:12px;font-weight:600;display:flex;align-items:center;gap:8px;border-bottom:1px solid var(--s4)}
.ag-res-b{padding:14px;background:var(--bg);font-size:13px;color:var(--txtm);font-family:var(--fm);white-space:pre-wrap}

.ag-typing{display:flex;align-items:center;gap:8px;padding:8px 14px;color:var(--txtd);font-size:13px;font-style:italic}
.ag-typing span{animation:blink 1.4s infinite both}
.ag-typing span:nth-child(2){animation-delay:0.2s}
.ag-typing span:nth-child(3){animation-delay:0.4s}
@keyframes blink{0%,80%,100%{opacity:0}40%{opacity:1}}

.ag-act{display:flex;align-items:center;gap:8px;padding:6px 10px;background:var(--s3);border:1px solid var(--s4);border-radius:6px;font-size:12px;color:var(--txtd);margin:4px 0}
.ag-act-i{font-size:14px;animation:spin 1s linear infinite}
@keyframes spin{from{transform:rotate(0deg)}to{transform:rotate(360deg)}}

.ag-snd{background:var(--s2);border:1px solid var(--s4);border-radius:8px;padding:8px;font-size:12px;color:var(--txtd);margin:8px 0}
.ag-snd-h{font-weight:600;margin-bottom:4px;color:var(--txtm)}

.ag-rat{display:flex;gap:8px;align-items:center;margin:8px 0}
.ag-rat-b{padding:4px 10px;background:var(--s3);border:1px solid var(--s4);border-radius:4px;font-size:12px;cursor:pointer;transition:all 0.2s}
.ag-rat-b:hover{border-color:var(--cy)}
.ag-rat-b.on{background:var(--em);border-color:var(--em);color:#fff}

.ag-st{padding:12px;background:var(--s3);border:1px solid var(--s4);border-radius:8px;margin:8px 0}
.ag-st-h{display:flex;align-items:center;gap:8px;font-size:13px;font-weight:500;margin-bottom:8px}
.ag-st-b{display:flex;flex-direction:column;gap:6px}
.ag-st-r{display:flex;justify-content:space-between;align-items:center;font-size:12px}
.ag-st-r-l{color:var(--txtd)}
.ag-st-r-v{color:var(--txtm);font-family:var(--fm)}

.ag-poll{border:1px solid var(--s4);border-radius:8px;overflow:hidden;margin:8px 0}
.ag-poll-h{padding:10px 14px;background:var(--s3);font-size:13px;font-weight:500;border-bottom:1px solid var(--s4)}
.ag-poll-o{padding:8px 14px;display:flex;align-items:center;gap:8px;cursor:pointer;transition:all 0.15s;border-bottom:1px solid var(--s4)}
.ag-poll-o:last-child{border-bottom:none}
.ag-poll-o:hover{background:var(--s3)}
.ag-poll-o-bar{flex:1;height:6px;background:var(--s4);border-radius:3px;overflow:hidden}
.ag-poll-o-bar-f{height:100%;background:var(--em);border-radius:3px}
.ag-poll-o-v{font-size:12px;color:var(--txtd);min-width:40px;text-align:right}

.ag-snd-m{display:flex;gap:8px;flex-wrap:wrap;margin:4px 0}
.ag-snd-mi{flex:1;min-width:120px;padding:8px;background:var(--s3);border:1px solid var(--s4);border-radius:6px;text-align:center;cursor:pointer;transition:all 0.2s;font-size:12px}
.ag-snd-mi:hover{border-color:var(--cy)}
.ag-snd-mi img{max-width:100%;border-radius:4px;margin-bottom:4px}
</style>
</head>
<body>

<!-- Hero Section -->
<div class="hero">
<div class="container">
<div class="hero-b">A2UI Registry Specification</div>
<h1>Flint Component Registry</h1>
<p>Complete reference for all A2UI base primitives, registry schema, API surfaces, and assembly pipelines. Interactive HTMX examples with the KnowMe design system.</p>
