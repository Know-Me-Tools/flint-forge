<!DOCTYPE html>
<html lang="en"><head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Flint A2UI - Document Management</title>
<script src="https://unpkg.com/htmx.org@2.0.4"></script>
<script defer src="https://cdn.jsdelivr.net/npm/alpinejs@3.x.x/dist/cdn.min.js"></script>
<link href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@400;500;600;700&family=Inter:wght@400;500;600&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet">
<style>
:root{--bg:#0B0F14;--s1:#131A22;--s2:#1A232E;--s3:#0E141B;--s4:#202B38;--s5:#2A3542;
--txt:#E8EDF3;--txtm:#B4BECB;--txtd:#97A1AE;--em:#FF6A3D;--emd:#E04E28;--cy:#34CFE6;
--gr:#4FD18B;--yl:#F4B942;--rd:#F05D5D;--fd:'Space Grotesk';--fb:'Inter';--fm:'JetBrains Mono'}
*{box-sizing:border-box;margin:0;padding:0}
html{scroll-behavior:smooth}
body{background:var(--bg);color:var(--txt);font-family:var(--fb);font-size:14px;line-height:1.6;overflow-x:hidden}

h1,h2,h3,h4{font-family:var(--fd);font-weight:600;letter-spacing:-0.02em}
h1{font-size:2.8rem;margin-bottom:1rem}h2{font-size:1.8rem;margin:2rem 0 1rem}h3{font-size:1.3rem;margin:1.5rem 0 0.8rem}
p{margin-bottom:1rem;color:var(--txtm)}

.container{max-width:1400px;margin:0 auto;padding:0 24px}
.grid{display:grid;gap:24px}
.grid-2{grid-template-columns:repeat(2,1fr)}
.grid-3{grid-template-columns:repeat(3,1fr)}
@media(max-width:900px){.grid-2,.grid-3{grid-template-columns:1fr}}

.hero{background:var(--s1);border-bottom:1px solid var(--s4);padding:60px 0;text-align:center}
.hero-b{display:inline-block;background:rgba(255,106,61,0.15);color:var(--em);padding:6px 16px;border-radius:20px;font-size:12px;font-weight:600;text-transform:uppercase;letter-spacing:1px;margin-bottom:16px}
.hero p{max-width:700px;margin:0 auto 24px;color:var(--txtd)}

.sec{background:var(--s1);border:1px solid var(--s4);border-radius:12px;padding:24px;margin-bottom:24px}
.sec-h{display:flex;align-items:center;gap:12px;margin-bottom:16px}
.sec-h .icon{width:36px;height:36px;background:var(--s3);border-radius:8px;display:flex;align-items:center;justify-content:center;font-size:18px}
.sec-h h3{margin:0}
.sec-h .tag{font-size:11px;background:var(--s3);color:var(--txtd);padding:2px 8px;border-radius:4px;border:1px solid var(--s4)}

.demo{background:var(--bg);border:1px solid var(--s4);border-radius:8px;padding:20px;margin:16px 0}
.demo-label{font-size:11px;text-transform:uppercase;letter-spacing:1px;color:var(--txtd);margin-bottom:8px;font-weight:600}

.btn{display:inline-flex;align-items:center;gap:8px;padding:8px 16px;border-radius:8px;border:none;font-size:13px;font-weight:500;cursor:pointer;transition:all 0.2s;text-decoration:none}
.btn-p{background:var(--em);color:#fff}
.btn-p:hover{background:var(--emd);transform:translateY(-1px)}
.btn-s{background:var(--s3);color:var(--txt);border:1px solid var(--s4)}
.btn-s:hover{border-color:var(--cy)}
.btn-g{background:var(--s3);color:var(--gr);border:1px solid rgba(79,209,139,0.3)}
.btn-r{background:var(--s3);color:var(--rd);border:1px solid rgba(240,93,93,0.3)}
.btn-ghost{background:transparent;color:var(--txtm);border:1px solid var(--s4)}
.btn-ghost:hover{color:var(--txt);border-color:var(--cy)}
.btn-sm{padding:4px 10px;font-size:12px}
.btn-lg{padding:12px 24px;font-size:14px}
.btn-i{padding:8px}

.inp{width:100%;background:var(--bg);border:1px solid var(--s4);border-radius:8px;padding:10px 14px;color:var(--txt);font-size:13px;transition:all 0.2s}
.inp:focus{outline:none;border-color:var(--cy);box-shadow:0 0 0 3px rgba(52,207,230,0.1)}
.inp::placeholder{color:var(--txtd)}
.lbl{display:block;font-size:12px;font-weight:500;color:var(--txtm);margin-bottom:6px;text-transform:uppercase;letter-spacing:0.5px}
.fg{margin-bottom:16px}
.sel{width:100%;background:var(--bg);border:1px solid var(--s4);border-radius:8px;padding:10px 14px;color:var(--txt);font-size:13px;cursor:pointer}
.sel:focus{outline:none;border-color:var(--cy)}
.tx{width:100%;min-height:100px;background:var(--bg);border:1px solid var(--s4);border-radius:8px;padding:10px 14px;color:var(--txt);font-size:13px;resize:vertical}

.tbl{width:100%;border-collapse:collapse;font-size:13px}
.tbl th{text-align:left;padding:10px 12px;background:var(--s3);color:var(--txtd);font-weight:600;font-size:11px;text-transform:uppercase;letter-spacing:0.5px;border-bottom:1px solid var(--s4)}
.tbl td{padding:10px 12px;border-bottom:1px solid var(--s4);color:var(--txtm)}
.tbl tr:hover td{background:rgba(52,207,230,0.05)}
.tbl tr:last-child td{border-bottom:none}

.bd-g{display:inline-block;padding:2px 8px;border-radius:4px;font-size:11px;font-weight:600;background:rgba(79,209,139,0.15);color:var(--gr)}
.bd-y{display:inline-block;padding:2px 8px;border-radius:4px;font-size:11px;font-weight:600;background:rgba(244,185,66,0.15);color:var(--yl)}
.bd-r{display:inline-block;padding:2px 8px;border-radius:4px;font-size:11px;font-weight:600;background:rgba(240,93,93,0.15);color:var(--rd)}
.bd-e{display:inline-block;padding:2px 8px;border-radius:4px;font-size:11px;font-weight:600;background:rgba(255,106,61,0.15);color:var(--em)}
.bd-c{display:inline-block;padding:2px 8px;border-radius:4px;font-size:11px;font-weight:600;background:rgba(52,207,230,0.15);color:var(--cy)}
.bd-d{display:inline-block;padding:2px 8px;border-radius:4px;font-size:11px;font-weight:600;background:var(--s3);color:var(--txtd)}

.card{background:var(--s2);border:1px solid var(--s4);border-radius:10px;padding:20px;transition:all 0.2s}
.card:hover{border-color:var(--cy);transform:translateY(-2px)}
.card-h{font-size:14px;font-weight:600;margin-bottom:8px;color:var(--txt)}
.card-d{font-size:13px;color:var(--txtd);margin-bottom:12px}

.tbs{display:flex;border-bottom:1px solid var(--s4);gap:4px;margin-bottom:16px}
.tb{padding:10px 16px;border:none;background:none;color:var(--txtd);font-size:13px;cursor:pointer;border-bottom:2px solid transparent;transition:all 0.2s}
.tb.on{color:var(--cy);border-bottom-color:var(--cy)}
.tb:hover{color:var(--txt)}

.acc{border:1px solid var(--s4);border-radius:8px;margin-bottom:8px;overflow:hidden}
.acc-h{display:flex;align-items:center;justify-content:space-between;padding:12px 16px;background:var(--s2);cursor:pointer;font-weight:500;font-size:13px}
.acc-b{padding:12px 16px;background:var(--bg);border-top:1px solid var(--s4);font-size:13px;color:var(--txtm)}

.tbar{display:flex;align-items:center;gap:16px;padding:12px 24px;background:var(--s1);border-bottom:1px solid var(--s4);position:sticky;top:0;z-index:100}
.tbar-l{font-family:var(--fd);font-weight:700;font-size:18px;color:var(--em)}
.tbar-n{display:flex;gap:4px}
.tbar-n a{padding:6px 12px;border-radius:6px;color:var(--txtm);text-decoration:none;font-size:13px;transition:all 0.2s}
.tbar-n a:hover,.tbar-n a.on{background:var(--s3);color:var(--txt)}
.snav{width:260px;background:var(--s1);border-right:1px solid var(--s4);min-height:100vh;position:fixed;top:0;left:0;overflow-y:auto;z-index:99}
.snav-h{padding:16px 20px;border-bottom:1px solid var(--s4);display:flex;align-items:center;gap:12px}
.snav-l{display:flex;align-items:center;gap:10px;font-family:var(--fd);font-weight:700;font-size:16px}
.snav-li{width:32px;height:32px;background:var(--em);border-radius:8px;display:flex;align-items:center;justify-content:center;color:#fff;font-weight:700}
.snav-i{display:flex;align-items:center;gap:10px;padding:10px 20px;color:var(--txtm);text-decoration:none;font-size:13px;transition:all 0.2s;border-left:3px solid transparent}
.snav-i:hover{background:var(--s2);color:var(--txt)}
.snav-i.on{border-left-color:var(--em);background:var(--s2);color:var(--txt)}

.av{width:36px;height:36px;border-radius:50%;background:var(--s3);display:flex;align-items:center;justify-content:center;font-size:14px;font-weight:600;color:var(--cy);border:2px solid var(--s4)}
.av-sm{width:28px;height:28px;font-size:12px}

.pb{height:6px;background:var(--s3);border-radius:3px;overflow:hidden}
.pb-b{height:100%;background:var(--em);border-radius:3px;transition:width 0.5s ease}
.pf{display:flex;align-items:center;gap:12px;margin:8px 0}
.pf-l{font-size:12px;color:var(--txtd);min-width:80px}
.pf-b{flex:1}
.pf-v{font-size:12px;color:var(--txtm);min-width:40px;text-align:right}

.tl{position:relative;padding-left:24px}
.tl::before{content:'';position:absolute;left:7px;top:8px;bottom:8px;width:2px;background:var(--s4)}
.tl-i{position:relative;margin-bottom:20px}
.tl-d{position:absolute;left:-24px;top:4px;width:16px;height:16px;border-radius:50%;background:var(--s3);border:2px solid var(--cy);z-index:1}
.tl-c{font-size:12px;font-weight:600;color:var(--txt);margin-bottom:4px}
.tl-t{font-size:11px;color:var(--txtd);margin-bottom:4px}
.tl-x{font-size:13px;color:var(--txtm)}

.mc{background:var(--s2);border:1px solid var(--s4);border-radius:10px;padding:20px;transition:all 0.2s}
.mc-v{font-size:28px;font-weight:700;font-family:var(--fd);color:var(--txt);margin-bottom:4px}
.mc-l{font-size:12px;color:var(--txtd);text-transform:uppercase;letter-spacing:0.5px;margin-bottom:8px}
.mc-d{display:flex;align-items:center;gap:6px;font-size:13px}
.mc-d.up{color:var(--gr)}.mc-d.down{color:var(--rd)}

.stp{display:flex;align-items:center;gap:8px;margin:24px 0}
.st{display:flex;align-items:center;gap:8px}
.stc{width:32px;height:32px;border-radius:50%;display:flex;align-items:center;justify-content:center;font-size:13px;font-weight:600;background:var(--s3);border:2px solid var(--s4);color:var(--txtd)}
.stc.on{background:var(--em);border-color:var(--em);color:#fff}
.stc.done{background:var(--gr);border-color:var(--gr);color:#fff}
.stl{flex:1;height:2px;background:var(--s4);min-width:40px}
.stl.on{background:var(--em)}

.pg{display:flex;gap:4px;justify-content:center;align-items:center}
.pg-b{padding:6px 12px;border:1px solid var(--s4);background:var(--s2);color:var(--txtm);border-radius:6px;cursor:pointer;font-size:13px;transition:all 0.2s}
.pg-b:hover{border-color:var(--cy);color:var(--txt)}
.pg-b.on{background:var(--em);border-color:var(--em);color:#fff}

.fb{display:flex;gap:12px;align-items:center;flex-wrap:wrap;padding:16px;background:var(--s2);border:1px solid var(--s4);border-radius:10px;margin-bottom:16px}
.ft{flex:1;min-width:200px;position:relative}
.ft-i{width:100%;padding:10px 14px 10px 36px;background:var(--bg);border:1px solid var(--s4);border-radius:8px;color:var(--txt);font-size:13px}
.ft::before{content:'🔍';position:absolute;left:12px;top:50%;transform:translateY(-50%);font-size:12px;opacity:0.6}

.htmx-added{animation:fadeIn 0.3s ease}
.htmx-swapping{animation:fadeOut 0.2s ease}
@keyframes fadeIn{from{opacity:0;transform:translateY(8px)}to{opacity:1;transform:translateY(0)}}
@keyframes fadeOut{from{opacity:1}to{opacity:0}}

[x-cloak]{display:none !important}

.page{display:flex;min-height:100vh}
.page .main{flex:1;padding:24px;min-width:0;margin-left:260px}
@media(max-width:900px){.snav{display:none}.page .main{margin-left:0}}

.comp-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(350px,1fr));gap:16px}
.comp-item{background:var(--bg);border:1px solid var(--s4);border-radius:8px;padding:16px}
.comp-item h4{font-size:13px;margin-bottom:12px;color:var(--txtd);text-transform:uppercase;letter-spacing:0.5px}
.demo-code{background:var(--s3);border:1px solid var(--s4);border-radius:6px;padding:12px;margin-top:12px;font-family:var(--fm);font-size:11px;overflow-x:auto;color:var(--txtd)}

.sw{display:flex;align-items:center;gap:10px;cursor:pointer}
.sw-i{position:relative;width:44px;height:24px;background:var(--s4);border-radius:12px;transition:all 0.2s}
.sw-i.on{background:var(--em)}
.sw-i::after{content:'';position:absolute;top:2px;left:2px;width:20px;height:20px;background:#fff;border-radius:50%;transition:all 0.2s}
.sw-i.on::after{left:22px}
.sw-l{font-size:13px;color:var(--txtm)}

.ttp{position:relative;display:inline-block}
.ttp-b{position:absolute;bottom:100%;left:50%;transform:translateX(-50%);padding:6px 10px;background:var(--s2);border:1px solid var(--s4);border-radius:6px;font-size:11px;white-space:nowrap;opacity:0;visibility:hidden;transition:all 0.2s;margin-bottom:6px;z-index:50}
.ttp:hover .ttp-b{opacity:1;visibility:visible}

.lst{border:1px solid var(--s4);border-radius:8px;overflow:hidden}
.lst-i{display:flex;align-items:center;gap:12px;padding:12px 16px;border-bottom:1px solid var(--s4);transition:all 0.15s}
.lst-i:last-child{border-bottom:none}
.lst-i:hover{background:var(--s3)}
.lst-i-c{flex:1}
.lst-i-t{font-size:13px;font-weight:500;color:var(--txt)}
.lst-i-d{font-size:11px;color:var(--txtd);margin-top:2px}
.lst-i-a{display:flex;gap:4px;opacity:0;transition:opacity 0.2s}
.lst-i:hover .lst-i-a{opacity:1}

/* Document specific styles */
.doc-tree{font-size:13px}
.doc-tree-f{display:flex;align-items:center;gap:8px;padding:6px 8px;border-radius:6px;cursor:pointer;transition:all 0.15s}
.doc-tree-f:hover{background:var(--s3)}
.doc-tree-f.on{background:var(--s3);border-left:2px solid var(--em)}
.doc-tree-f-ic{font-size:16px}
.doc-tree-f-n{flex:1}
.doc-tree-f-nm{font-size:13px}
.doc-tree-f-nd{font-size:11px;color:var(--txtd)}

.doc-prev{background:var(--s2);border:1px solid var(--s4);border-radius:10px;padding:24px;min-height:400px}
.doc-prev-h{display:flex;align-items:center;justify-content:space-between;margin-bottom:16px;padding-bottom:16px;border-bottom:1px solid var(--s4)}
.doc-prev-t{font-size:18px;font-weight:600;font-family:var(--fd)}
.doc-prev-m{font-size:12px;color:var(--txtd)}
.doc-prev-b{font-size:13px;color:var(--txtm);line-height:1.8}
.doc-prev-b h1{font-size:24px;margin-bottom:16px}
.doc-prev-b h2{font-size:18px;margin:24px 0 12px}
.doc-prev-b p{margin-bottom:12px}
.doc-prev-b ul{margin:12px 0 12px 24px}
.doc-prev-b li{margin-bottom:4px}

.wf-st{display:flex;align-items:center;gap:12px}
.wf-st-l{font-size:12px;color:var(--txtd);min-width:100px}
.wf-st-b{flex:1;height:8px;background:var(--s4);border-radius:4px;overflow:hidden}
.wf-st-bf{height:100%;border-radius:4px;transition:width 0.5s ease}
.wf-st-v{font-size:12px;color:var(--txtm);min-width:60px;text-align:right}

.ver-h{display:flex;align-items:center;gap:8px;padding:8px 12px;background:var(--s3);border-radius:6px;margin-bottom:8px;font-size:12px}
.ver-h.on{border:1px solid var(--em)}
.ver-h-d{color:var(--txtd);margin-left:auto;font-family:var(--fm)}
</style>
</head>
<body>

<!-- Hero Section -->
<div class="hero">
<div class="container">
<div class="hero-b">Document Management</div>
<h1>Flint Docs</h1>
<p>A document management and workflow interface built with A2UI components. Browse files, preview documents, manage versions, and track approval workflows.</p>
<div style="display:flex;gap:16px;justify-content:center;flex-wrap:wrap;margin-top:24px;">
<a href="FLINT-A2UI-REGISTRY-SPEC.html" class="btn btn-ghost">← Registry Spec</a>
<a href="FLINT-A2UI-SITUATIONAL.html" class="btn btn-ghost">← Situational</a>
<a href="FLINT-A2UI-VIDEO-GEN.html" class="btn btn-s">Video Gen →</a>
<a href="FLINT-A2UI-CRM.html" class="btn btn-s">CRM →</a>
</div>
</div>
</div>

<!-- Page Layout -->
<div class="page">
<!-- Sidebar Navigation -->
<nav class="snav">
<div class="snav-h">
<div class="snav-l"><div class="snav-li">F</div><span>Flint Docs</span></div>
</div>
<div style="padding:12px 0;">
<a href="#browser" class="snav-i on">📁 File Browser</a>
<a href="#preview" class="snav-i">📄 Document Preview</a>
<a href="#versions" class="snav-i">🔄 Versions</a>
<a href="#workflow" class="snav-i">📋 Workflow</a>
<a href="#upload" class="snav-i">📤 Upload</a>
</div>
</nav>

<!-- Main Content -->
<main class="main">
<div class="container">

<!-- File Browser Section -->
<section id="browser" class="sec">
<div class="sec-h"><div class="icon">📁</div><h3>File Browser</h3><span class="tag">Explorer</span></div>

<div class="comp-grid">
<div class="comp-item" style="grid-column:1/-1;">
<h4>📁 Document Tree</h4>
<div class="demo">
<div class="demo-label">File Explorer</div>
<div class="grid grid-2" style="gap:16px;grid-template-columns:280px 1fr;">
<div style="background:var(--s2);border:1px solid var(--s4);border-radius:8px;padding:12px;overflow-y:auto;max-height:400px;">
<div class="doc-tree">
<div class="doc-tree-f on"><span class="doc-tree-f-ic">📁</span><div class="doc-tree-f-n"><div class="doc-tree-f-nm">Documents</div><div class="doc-tree-f-nd">24 items</div></div></div>
<div style="margin-left:20px;">
<div class="doc-tree-f"><span class="doc-tree-f-ic">📁</span><div class="doc-tree-f-n"><div class="doc-tree-f-nm">Specifications</div><div class="doc-tree-f-nd">8 items</div></div></div>
<div class="doc-tree-f"><span class="doc-tree-f-ic">📁</span><div class="doc-tree-f-n"><div class="doc-tree-f-nm">Designs</div><div class="doc-tree-f-nd">5 items</div></div></div>
<div class="doc-tree-f on"><span class="doc-tree-f-ic">📁</span><div class="doc-tree-f-n"><div class="doc-tree-f-nm">Reports</div><div class="doc-tree-f-nd">6 items</div></div></div>
<div style="margin-left:20px;">
<div class="doc-tree-f on"><span class="doc-tree-f-ic">📄</span><div class="doc-tree-f-n"><div class="doc-tree-f-nm">Q4-2024.md</div><div class="doc-tree-f-nd">2.4 KB • 2h ago</div></div></div>
<div class="doc-tree-f"><span class="doc-tree-f-ic">📄</span><div class="doc-tree-f-n"><div class="doc-tree-f-nm">Analytics.pdf</div><div class="doc-tree-f-nd">1.8 MB • 1d ago</div></div></div>
</div>
<div class="doc-tree-f"><span class="doc-tree-f-ic">📁</span><div class="doc-tree-f-n"><div class="doc-tree-f-nm">Contracts</div><div class="doc-tree-f-nd">5 items</div></div></div>
</div>
</div>
</div>
<div class="doc-prev">
<div class="doc-prev-h">
<div><div class="doc-prev-t">Q4-2024.md</div><div class="doc-prev-m">Reports / Q4-2024.md • Last edited by Alice Chen • 2h ago</div></div>
<div style="display:flex;gap:8px;">
<button class="btn btn-s btn-sm">✏️ Edit</button>
<button class="btn btn-s btn-sm">🔄 History</button>
<button class="btn btn-s btn-sm">⬇️ Download</button>
</div>
</div>
<div class="doc-prev-b">
<h1>Q4 2024 Performance Report</h1>
<h2>Executive Summary</h2>
<p>This report covers the fourth quarter performance metrics for the Flint platform. Key highlights include a 12.5% increase in user engagement and a 8.3% growth in revenue compared to Q3 2024.</p>
<h2>Key Metrics</h2>
<ul>
<li>Total Active Users: 12,847 (+12.5%)</li>
<li>Monthly Recurring Revenue: $84,200 (+8.3%)</li>
<li>Component Registry: 156 components registered</li>
<li>System Uptime: 99.9% (+0.1%)</li>
</ul>
<h2>Component Registry Growth</h2>
<p>The A2UI Component Registry saw significant growth this quarter with 24 new components added. The most impactful additions were the Agent Chat interface, Matrix messaging protocol, and Video streaming components.</p>
<h2>Conclusion</h2>
<p>Q4 2024 demonstrated strong platform growth across all key metrics. The focus for Q1 2025 will be on expanding the registry to 200+ components and improving the semantic search capabilities.</p>
</div>
</div>
</div>
</div>
<div class="demo-code">{"type":"file_browser","root":"Documents","items":["Specifications","Designs","Reports","Contracts"],"preview":"markdown","hx_get":"/api/documents/{path}"}</div>
</div>
</div>
</section>

<!-- Versions Section -->
<section id="versions" class="sec">
<div class="sec-h"><div class="icon">🔄</div><h3>Version History</h3><span class="tag">Version Control</span></div>

<div class="comp-grid">
<div class="comp-item" style="grid-column:1/-1;">
<h4>🔄 Document Versions</h4>
<div class="demo">
<div class="demo-label">Version Timeline</div>
<div class="tl">
<div class="tl-i">
<div class="tl-d" style="border-color:var(--em);background:var(--em);"></div>
<div class="ver-h on" style="margin-left:8px;margin-bottom:0;">
<div class="av av-sm" style="color:var(--cy);">AC</div>
<div><div style="font-size:13px;font-weight:600;">Version 3.2 (Current)</div><div style="font-size:11px;color:var(--txtd);">Alice Chen • Final review complete</div></div>
<div class="ver-h-d">2h ago</div>
</div>
</div>
<div class="tl-i">
<div class="tl-d"></div>
<div class="ver-h" style="margin-left:8px;margin-bottom:0;">
<div class="av av-sm" style="color:var(--gr);">BS</div>
<div><div style="font-size:13px;font-weight:600;">Version 3.1</div><div style="font-size:11px;color:var(--txtd);">Bob Smith • Added analytics section</div></div>
<div class="ver-h-d">1d ago</div>
</div>
</div>
<div class="tl-i">
<div class="tl-d"></div>
<div class="ver-h" style="margin-left:8px;margin-bottom:0;">
<div class="av av-sm" style="color:var(--yl);">CW</div>
<div><div style="font-size:13px;font-weight:600;">Version 3.0</div><div style="font-size:11px;color:var(--txtd);">Carol Wu • Restructured layout</div></div>
<div class="ver-h-d">3d ago</div>
</div>
</div>
<div class="tl-i">
<div class="tl-d"></div>
<div class="ver-h" style="margin-left:8px;margin-bottom:0;">
<div class="av av-sm" style="color:var(--rd);">DJ</div>
<div><div style="font-size:13px;font-weight:600;">Version 2.1</div><div style="font-size:11px;color:var(--txtd);">David Johnson • Initial draft</div></div>
<div class="ver-h-d">1w ago</div>
</div>
</div>
<div class="tl-i">
<div class="tl-d"></div>
<div class="ver-h" style="margin-left:8px;margin-bottom:0;">
<div class="av av-sm" style="color:var(--txtd);">DJ</div>
<div><div style="font-size:13px;font-weight:600;">Version 1.0</div><div style="font-size:11px;color:var(--txtd);">David Johnson • Created document</div></div>
<div class="ver-h-d">2w ago</div>
</div>
</div>
</div>
</div>
<div class="demo-code">{"type":"version_history","document":"Q4-2024.md","versions":[{"version":"3.2","author":"Alice Chen","status":"current"},...],"hx_get":"/api/versions/{doc_id}"}</div>
</div>
</div>
</div>
</section>

<!-- Workflow Section -->
<section id="workflow" class="sec">
<div class="sec-h"><div class="icon">📋</div><h3>Approval Workflow</h3><span class="tag">Process</span></div>

<div class="comp-grid">
<div class="comp-item" style="grid-column:1/-1;">
<h4>📋 Document Approval</h4>
<div class="demo">
<div class="demo-label">Workflow Status</div>
<div class="stp">
<div class="st"><div class="stc done">✓</div><div class="stt">Draft</div></div>
<div class="stl on"></div>
<div class="st"><div class="stc done">✓</div><div class="stt">Review</div></div>
<div class="stl on"></div>
<div class="st"><div class="stc on">3</div><div class="stt">Approve</div></div>
<div class="stl"></div>
<div class="st"><div class="stc">4</div><div class="stt">Publish</div></div>
</div>
<div style="margin-top:24px;">
<div class="wf-st" style="margin-bottom:12px;"><span class="wf-st-l">Draft</span><div class="wf-st-b"><div class="wf-st-bf" style="width:100%;background:var(--gr);"></div></div><span class="wf-st-v">Completed</span></div>
<div class="wf-st" style="margin-bottom:12px;"><span class="wf-st-l">Review</span><div class="wf-st-b"><div class="wf-st-bf" style="width:100%;background:var(--gr);"></div></div><span class="wf-st-v">Completed</span></div>
<div class="wf-st" style="margin-bottom:12px;"><span class="wf-st-l">Approve</span><div class="wf-st-b"><div class="wf-st-bf" style="width:60%;background:var(--yl);"></div></div><span class="wf-st-v">In Progress</span></div>
<div class="wf-st"><span class="wf-st-l">Publish</span><div class="wf-st-b"><div class="wf-st-bf" style="width:0%;background:var(--s4);"></div></div><span class="wf-st-v">Pending</span></div>
</div>
<div style="display:flex;gap:12px;margin-top:24px;align-items:center;">
<div style="flex:1;">
<div style="font-size:13px;font-weight:500;margin-bottom:8px;">Approvers</div>
<div style="display:flex;gap:8px;">
<div style="display:flex;align-items:center;gap:8px;padding:8px 12px;background:var(--s3);border:1px solid var(--s4);border-radius:8px;">
<div class="av av-sm" style="color:var(--gr);">BS</div><div><div style="font-size:12px;font-weight:500;">Bob Smith</div><div style="font-size:11px;color:var(--gr);">✓ Approved</div></div>
</div>
<div style="display:flex;align-items:center;gap:8px;padding:8px 12px;background:var(--s3);border:1px solid var(--s4);border-radius:8px;">
<div class="av av-sm" style="color:var(--yl);">CW</div><div><div style="font-size:12px;font-weight:500;">Carol Wu</div><div style="font-size:11px;color:var(--yl);">⏳ Pending</div></div>
</div>
<div style="display:flex;align-items:center;gap:8px;padding:8px 12px;background:var(--s3);border:1px solid var(--s4);border-radius:8px;opacity:0.6;">
<div class="av av-sm" style="color:var(--txtd);">DJ</div><div><div style="font-size:12px;font-weight:500;">David Johnson</div><div style="font-size:11px;color:var(--txtd);">Not started</div></div>
</div>
</div>
</div>
<div style="display:flex;gap:8px;">
<button class="btn btn-p" hx-post="/api/workflow/approve" hx-target="#wf-result">Approve</button>
<button class="btn btn-r" hx-post="/api/workflow/reject" hx-target="#wf-result">Reject</button>
<button class="btn btn-ghost" hx-post="/api/workflow/request-changes" hx-target="#wf-result">Request Changes</button>
</div>
</div>
<div id="wf-result" style="margin-top:12px;"></div>
</div>
<div class="demo-code">{"type":"approval_workflow","stages":["Draft","Review","Approve","Publish"],"current":"Approve","approvers":[{"name":"Bob Smith","status":"approved"},...],"hx_post":"/api/workflow/approve"}</div>
</div>
</div>
</div>
</section>

<!-- Upload Section -->
<section id="upload" class="sec">
<div class="sec-h"><div class="icon">📤</div><h3>Upload Documents</h3><span class="tag">File Transfer</span></div>

<div class="comp-grid">
<div class="comp-item" style="grid-column:1/-1;">
<h4>📤 Drag & Drop Upload</h4>
<div class="demo">
<div class="demo-label">Upload Zone</div>
<div style="padding:48px 24px;border:2px dashed var(--s4);border-radius:12px;text-align:center;" hx-encoding="multipart/form-data" hx-post="/api/documents/upload" hx-target="#upload-result" hx-indicator="#upload-spinner">
<div style="font-size:48px;margin-bottom:16px;">📤</div>
<div style="font-size:16px;font-weight:600;margin-bottom:8px;">Drop files to upload</div>
<div style="font-size:13px;color:var(--txtd);margin-bottom:16px;">or click to browse (PDF, DOCX, MD up to 50MB)</div>
<input type="file" class="inp" style="border:none;padding:0;text-align:center;" multiple accept=".pdf,.docx,.md,.txt">
</div>
<div id="upload-spinner" class="htmx-indicator" style="margin-top:12px;text-align:center;">
<div class="pf"><span class="pf-l">Uploading...</span><div class="pf-b"><div class="pb"><div class="pb-b" style="width:45%"></div></div></div><span class="pf-v">45%</span></div>
</div>
<div id="upload-result" style="margin-top:12px;"></div>
<div style="margin-top:16px;">
<div style="font-size:13px;font-weight:600;margin-bottom:8px;">Recent Uploads</div>
<div class="lst">
<div class="lst-i"><div class="doc-tree-f-ic">📄</div><div class="lst-i-c"><div class="lst-i-t">Q4-2024-Report.pdf</div><div class="lst-i-d">2.4 MB • Uploaded 2h ago</div></div><span class="bd-g">Complete</span></div>
<div class="lst-i"><div class="doc-tree-f-ic">📄</div><div class="lst-i-c"><div class="lst-i-t">Design-System-v2.fig</div><div class="lst-i-d">18.5 MB • Uploaded 1d ago</div></div><span class="bd-g">Complete</span></div>
<div class="lst-i"><div class="doc-tree-f-ic">📄</div><div class="lst-i-c"><div class="lst-i-t">API-Specification.md</div><div class="lst-i-d">45 KB • Uploaded 3d ago</div></div><span class="bd-g">Complete</span></div>
</div>
</div>
</div>
<div class="demo-code">{"type":"document_upload","accept":".pdf,.docx,.md,.txt","max_size":"50MB","multiple":true,"hx_post":"/api/documents/upload"}</div>
</div>
</div>
</div>
</section>

</div></main></div>
</body></html>
