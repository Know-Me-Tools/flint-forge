<!DOCTYPE html>
<html lang="en"><head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Flint A2UI - Video Generative AI</title>
<script src="https://unpkg.com/htmx.org@2.0.4"></script>
<script defer src="https://cdn.jsdelivr.net/npm/alpinejs@3.x.x/dist/cdn.min.js"></script>
<link href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@400;500;600;700&family=Inter:wght@400;500;600&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet">
<style>
:root{--bg:#0B0F14;--s1:#131A22;--s2:#1A232E;--s3:#0E141B;--s4:#202B38;--s5:#2A3542;
--txt:#E8EDF3;--txtm:#B4BECB;--txtd:#97A1AE;--em:#FF6A3D;--emd:#E04E28;--cy:#34CFE6;
--gr:#4FD18B;--yl:#F4B942;--rd:#F05D5D;--fd:'Space Grotesk';--fb:'Inter';--fm:'JetBrains Mono'}
*{box-sizing:border-box;margin:0;padding:0}
html{scroll-behavior:smooth}
body{background:var(--bg);color:var(--txt);font-family:var(--fb);font-size:14px;line-height:1.6;overflow-x:hidden}

h1,h2,h3,h4{font-family:var(--fd);font-weight:600;letter-spacing:-0.02em}
h1{font-size:2.8rem;margin-bottom:1rem}h2{font-size:1.8rem;margin:2rem 0 1rem}h3{font-size:1.3rem;margin:1.5rem 0 0.8rem}
p{margin-bottom:1rem;color:var(--txtm)}

.container{max-width:1400px;margin:0 auto;padding:0 24px}
.grid{display:grid;gap:24px}
.grid-2{grid-template-columns:repeat(2,1fr)}
.grid-3{grid-template-columns:repeat(3,1fr)}
@media(max-width:900px){.grid-2,.grid-3{grid-template-columns:1fr}}

.hero{background:var(--s1);border-bottom:1px solid var(--s4);padding:60px 0;text-align:center}
.hero-b{display:inline-block;background:rgba(255,106,61,0.15);color:var(--em);padding:6px 16px;border-radius:20px;font-size:12px;font-weight:600;text-transform:uppercase;letter-spacing:1px;margin-bottom:16px}
.hero p{max-width:700px;margin:0 auto 24px;color:var(--txtd)}

.sec{background:var(--s1);border:1px solid var(--s4);border-radius:12px;padding:24px;margin-bottom:24px}
.sec-h{display:flex;align-items:center;gap:12px;margin-bottom:16px}
.sec-h .icon{width:36px;height:36px;background:var(--s3);border-radius:8px;display:flex;align-items:center;justify-content:center;font-size:18px}
.sec-h h3{margin:0}
.sec-h .tag{font-size:11px;background:var(--s3);color:var(--txtd);padding:2px 8px;border-radius:4px;border:1px solid var(--s4)}

.demo{background:var(--bg);border:1px solid var(--s4);border-radius:8px;padding:20px;margin:16px 0}
.demo-label{font-size:11px;text-transform:uppercase;letter-spacing:1px;color:var(--txtd);margin-bottom:8px;font-weight:600}

.btn{display:inline-flex;align-items:center;gap:8px;padding:8px 16px;border-radius:8px;border:none;font-size:13px;font-weight:500;cursor:pointer;transition:all 0.2s;text-decoration:none}
.btn-p{background:var(--em);color:#fff}
.btn-p:hover{background:var(--emd);transform:translateY(-1px)}
.btn-s{background:var(--s3);color:var(--txt);border:1px solid var(--s4)}
.btn-s:hover{border-color:var(--cy)}
.btn-g{background:var(--s3);color:var(--gr);border:1px solid rgba(79,209,139,0.3)}
.btn-r{background:var(--s3);color:var(--rd);border:1px solid rgba(240,93,93,0.3)}
.btn-ghost{background:transparent;color:var(--txtm);border:1px solid var(--s4)}
.btn-ghost:hover{color:var(--txt);border-color:var(--cy)}
.btn-sm{padding:4px 10px;font-size:12px}
.btn-lg{padding:12px 24px;font-size:14px}
.btn-i{padding:8px}

.inp{width:100%;background:var(--bg);border:1px solid var(--s4);border-radius:8px;padding:10px 14px;color:var(--txt);font-size:13px;transition:all 0.2s}
.inp:focus{outline:none;border-color:var(--cy);box-shadow:0 0 0 3px rgba(52,207,230,0.1)}
.inp::placeholder{color:var(--txtd)}
.lbl{display:block;font-size:12px;font-weight:500;color:var(--txtm);margin-bottom:6px;text-transform:uppercase;letter-spacing:0.5px}
.fg{margin-bottom:16px}
.sel{width:100%;background:var(--bg);border:1px solid var(--s4);border-radius:8px;padding:10px 14px;color:var(--txt);font-size:13px;cursor:pointer}
.sel:focus{outline:none;border-color:var(--cy)}
.tx{width:100%;min-height:100px;background:var(--bg);border:1px solid var(--s4);border-radius:8px;padding:10px 14px;color:var(--txt);font-size:13px;resize:vertical}

.tbl{width:100%;border-collapse:collapse;font-size:13px}
.tbl th{text-align:left;padding:10px 12px;background:var(--s3);color:var(--txtd);font-weight:600;font-size:11px;text-transform:uppercase;letter-spacing:0.5px;border-bottom:1px solid var(--s4)}
.tbl td{padding:10px 12px;border-bottom:1px solid var(--s4);color:var(--txtm)}
.tbl tr:hover td{background:rgba(52,207,230,0.05)}
.tbl tr:last-child td{border-bottom:none}

.bd-g{display:inline-block;padding:2px 8px;border-radius:4px;font-size:11px;font-weight:600;background:rgba(79,209,139,0.15);color:var(--gr)}
.bd-y{display:inline-block;padding:2px 8px;border-radius:4px;font-size:11px;font-weight:600;background:rgba(244,185,66,0.15);color:var(--yl)}
.bd-r{display:inline-block;padding:2px 8px;border-radius:4px;font-size:11px;font-weight:600;background:rgba(240,93,93,0.15);color:var(--rd)}
.bd-e{display:inline-block;padding:2px 8px;border-radius:4px;font-size:11px;font-weight:600;background:rgba(255,106,61,0.15);color:var(--em)}
.bd-c{display:inline-block;padding:2px 8px;border-radius:4px;font-size:11px;font-weight:600;background:rgba(52,207,230,0.15);color:var(--cy)}
.bd-d{display:inline-block;padding:2px 8px;border-radius:4px;font-size:11px;font-weight:600;background:var(--s3);color:var(--txtd)}

.card{background:var(--s2);border:1px solid var(--s4);border-radius:10px;padding:20px;transition:all 0.2s}
.card:hover{border-color:var(--cy);transform:translateY(-2px)}
.card-h{font-size:14px;font-weight:600;margin-bottom:8px;color:var(--txt)}
.card-d{font-size:13px;color:var(--txtd);margin-bottom:12px}

.tbs{display:flex;border-bottom:1px solid var(--s4);gap:4px;margin-bottom:16px}
.tb{padding:10px 16px;border:none;background:none;color:var(--txtd);font-size:13px;cursor:pointer;border-bottom:2px solid transparent;transition:all 0.2s}
.tb.on{color:var(--cy);border-bottom-color:var(--cy)}
.tb:hover{color:var(--txt)}

.acc{border:1px solid var(--s4);border-radius:8px;margin-bottom:8px;overflow:hidden}
.acc-h{display:flex;align-items:center;justify-content:space-between;padding:12px 16px;background:var(--s2);cursor:pointer;font-weight:500;font-size:13px}
.acc-b{padding:12px 16px;background:var(--bg);border-top:1px solid var(--s4);font-size:13px;color:var(--txtm)}

.tbar{display:flex;align-items:center;gap:16px;padding:12px 24px;background:var(--s1);border-bottom:1px solid var(--s4);position:sticky;top:0;z-index:100}
.tbar-l{font-family:var(--fd);font-weight:700;font-size:18px;color:var(--em)}
.tbar-n{display:flex;gap:4px}
.tbar-n a{padding:6px 12px;border-radius:6px;color:var(--txtm);text-decoration:none;font-size:13px;transition:all 0.2s}
.tbar-n a:hover,.tbar-n a.on{background:var(--s3);color:var(--txt)}
.snav{width:260px;background:var(--s1);border-right:1px solid var(--s4);min-height:100vh;position:fixed;top:0;left:0;overflow-y:auto;z-index:99}
.snav-h{padding:16px 20px;border-bottom:1px solid var(--s4);display:flex;align-items:center;gap:12px}
.snav-l{display:flex;align-items:center;gap:10px;font-family:var(--fd);font-weight:700;font-size:16px}
.snav-li{width:32px;height:32px;background:var(--em);border-radius:8px;display:flex;align-items:center;justify-content:center;color:#fff;font-weight:700}
.snav-i{display:flex;align-items:center;gap:10px;padding:10px 20px;color:var(--txtm);text-decoration:none;font-size:13px;transition:all 0.2s;border-left:3px solid transparent}
.snav-i:hover{background:var(--s2);color:var(--txt)}
.snav-i.on{border-left-color:var(--em);background:var(--s2);color:var(--txt)}

.av{width:36px;height:36px;border-radius:50%;background:var(--s3);display:flex;align-items:center;justify-content:center;font-size:14px;font-weight:600;color:var(--cy);border:2px solid var(--s4)}
.av-sm{width:28px;height:28px;font-size:12px}

.pb{height:6px;background:var(--s3);border-radius:3px;overflow:hidden}
.pb-b{height:100%;background:var(--em);border-radius:3px;transition:width 0.5s ease}
.pf{display:flex;align-items:center;gap:12px;margin:8px 0}
.pf-l{font-size:12px;color:var(--txtd);min-width:80px}
.pf-b{flex:1}
.pf-v{font-size:12px;color:var(--txtm);min-width:40px;text-align:right}

.tl{position:relative;padding-left:24px}
.tl::before{content:'';position:absolute;left:7px;top:8px;bottom:8px;width:2px;background:var(--s4)}
.tl-i{position:relative;margin-bottom:20px}
.tl-d{position:absolute;left:-24px;top:4px;width:16px;height:16px;border-radius:50%;background:var(--s3);border:2px solid var(--cy);z-index:1}
.tl-c{font-size:12px;font-weight:600;color:var(--txt);margin-bottom:4px}
.tl-t{font-size:11px;color:var(--txtd);margin-bottom:4px}
.tl-x{font-size:13px;color:var(--txtm)}

.mc{background:var(--s2);border:1px solid var(--s4);border-radius:10px;padding:20px;transition:all 0.2s}
.mc-v{font-size:28px;font-weight:700;font-family:var(--fd);color:var(--txt);margin-bottom:4px}
.mc-l{font-size:12px;color:var(--txtd);text-transform:uppercase;letter-spacing:0.5px;margin-bottom:8px}
.mc-d{display:flex;align-items:center;gap:6px;font-size:13px}
.mc-d.up{color:var(--gr)}.mc-d.down{color:var(--rd)}

.stp{display:flex;align-items:center;gap:8px;margin:24px 0}
.st{display:flex;align-items:center;gap:8px}
.stc{width:32px;height:32px;border-radius:50%;display:flex;align-items:center;justify-content:center;font-size:13px;font-weight:600;background:var(--s3);border:2px solid var(--s4);color:var(--txtd)}
.stc.on{background:var(--em);border-color:var(--em);color:#fff}
.stc.done{background:var(--gr);border-color:var(--gr);color:#fff}
.stl{flex:1;height:2px;background:var(--s4);min-width:40px}
.stl.on{background:var(--em)}

.pg{display:flex;gap:4px;justify-content:center;align-items:center}
.pg-b{padding:6px 12px;border:1px solid var(--s4);background:var(--s2);color:var(--txtm);border-radius:6px;cursor:pointer;font-size:13px;transition:all 0.2s}
.pg-b:hover{border-color:var(--cy);color:var(--txt)}
.pg-b.on{background:var(--em);border-color:var(--em);color:#fff}

.fb{display:flex;gap:12px;align-items:center;flex-wrap:wrap;padding:16px;background:var(--s2);border:1px solid var(--s4);border-radius:10px;margin-bottom:16px}
.ft{flex:1;min-width:200px;position:relative}
.ft-i{width:100%;padding:10px 14px 10px 36px;background:var(--bg);border:1px solid var(--s4);border-radius:8px;color:var(--txt);font-size:13px}
.ft::before{content:'🔍';position:absolute;left:12px;top:50%;transform:translateY(-50%);font-size:12px;opacity:0.6}

.htmx-added{animation:fadeIn 0.3s ease}
.htmx-swapping{animation:fadeOut 0.2s ease}
@keyframes fadeIn{from{opacity:0;transform:translateY(8px)}to{opacity:1;transform:translateY(0)}}
@keyframes fadeOut{from{opacity:1}to{opacity:0}}

[x-cloak]{display:none !important}

.page{display:flex;min-height:100vh}
.page .main{flex:1;padding:24px;min-width:0;margin-left:260px}
@media(max-width:900px){.snav{display:none}.page .main{margin-left:0}}

.comp-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(350px,1fr));gap:16px}
.comp-item{background:var(--bg);border:1px solid var(--s4);border-radius:8px;padding:16px}
.comp-item h4{font-size:13px;margin-bottom:12px;color:var(--txtd);text-transform:uppercase;letter-spacing:0.5px}
.demo-code{background:var(--s3);border:1px solid var(--s4);border-radius:6px;padding:12px;margin-top:12px;font-family:var(--fm);font-size:11px;overflow-x:auto;color:var(--txtd)}

.sw{display:flex;align-items:center;gap:10px;cursor:pointer}
.sw-i{position:relative;width:44px;height:24px;background:var(--s4);border-radius:12px;transition:all 0.2s}
.sw-i.on{background:var(--em)}
.sw-i::after{content:'';position:absolute;top:2px;left:2px;width:20px;height:20px;background:#fff;border-radius:50%;transition:all 0.2s}
.sw-i.on::after{left:22px}
.sw-l{font-size:13px;color:var(--txtm)}

.ttp{position:relative;display:inline-block}
.ttp-b{position:absolute;bottom:100%;left:50%;transform:translateX(-50%);padding:6px 10px;background:var(--s2);border:1px solid var(--s4);border-radius:6px;font-size:11px;white-space:nowrap;opacity:0;visibility:hidden;transition:all 0.2s;margin-bottom:6px;z-index:50}
.ttp:hover .ttp-b{opacity:1;visibility:visible}

.lst{border:1px solid var(--s4);border-radius:8px;overflow:hidden}
.lst-i{display:flex;align-items:center;gap:12px;padding:12px 16px;border-bottom:1px solid var(--s4);transition:all 0.15s}
.lst-i:last-child{border-bottom:none}
.lst-i:hover{background:var(--s3)}
.lst-i-c{flex:1}
.lst-i-t{font-size:13px;font-weight:500;color:var(--txt)}
.lst-i-d{font-size:11px;color:var(--txtd);margin-top:2px}
.lst-i-a{display:flex;gap:4px;opacity:0;transition:opacity 0.2s}
.lst-i:hover .lst-i-a{opacity:1}

/* Video gen specific styles */
.vg-prompt{min-height:120px;font-size:14px;line-height:1.6}
.vg-opts{display:grid;grid-template-columns:repeat(auto-fill,minmax(200px,1fr));gap:12px}
.vg-opt{padding:12px;background:var(--s3);border:1px solid var(--s4);border-radius:8px;cursor:pointer;transition:all 0.2s}
.vg-opt:hover{border-color:var(--cy)}
.vg-opt.on{border-color:var(--em);background:rgba(255,106,61,0.1)}
.vg-opt-t{font-size:13px;font-weight:500;margin-bottom:4px}
.vg-opt-d{font-size:11px;color:var(--txtd)}

.vg-prev{aspect-ratio:16/9;background:var(--s3);border:1px solid var(--s4);border-radius:12px;position:relative;overflow:hidden;display:flex;align-items:center;justify-content:center;min-height:300px}
.vg-prev-pl{font-size:64px;opacity:0.3}
.vg-prev-b{position:absolute;bottom:0;left:0;right:0;padding:16px;background:linear-gradient(transparent,rgba(0,0,0,0.8));display:flex;align-items:center;gap:12px}
.vg-prev-ct{color:#fff;font-size:13px;font-family:var(--fm)}
.vg-prev-btn{background:none;border:none;color:#fff;font-size:20px;cursor:pointer;opacity:0.8;transition:opacity 0.2s}
.vg-prev-btn:hover{opacity:1}
.vg-prev-bar{flex:1;height:4px;background:rgba(255,255,255,0.3);border-radius:2px;cursor:pointer}
.vg-prev-bar-f{height:100%;background:var(--em);border-radius:2px;width:0%;transition:width 0.5s}

.vg-gen-st{display:flex;align-items:center;gap:12px;padding:16px;background:var(--s3);border:1px solid var(--s4);border-radius:8px;margin-bottom:12px}
.vg-gen-st-i{width:40px;height:40px;border-radius:50%;display:flex;align-items:center;justify-content:center;font-size:18px;animation:spin 2s linear infinite}
.vg-gen-st-t{font-size:13px;font-weight:500}
.vg-gen-st-d{font-size:12px;color:var(--txtd)}
@keyframes spin{from{transform:rotate(0deg)}to{transform:rotate(360deg)}}

.vg-thumb{display:grid;grid-template-columns:repeat(auto-fill,minmax(200px,1fr));gap:12px}
.vg-thumb-i{aspect-ratio:16/9;background:var(--s3);border:1px solid var(--s4);border-radius:8px;overflow:hidden;cursor:pointer;transition:all 0.2s;position:relative}
.vg-thumb-i:hover{border-color:var(--cy);transform:scale(1.02)}
.vg-thumb-i-o{position:absolute;inset:0;background:rgba(0,0,0,0.5);display:flex;align-items:center;justify-content:center;opacity:0;transition:opacity 0.2s}
.vg-thumb-i:hover .vg-thumb-i-o{opacity:1}
.vg-thumb-i-d{padding:8px;position:absolute;bottom:0;left:0;right:0;background:linear-gradient(transparent,rgba(0,0,0,0.8));font-size:11px;color:#fff}
</style>
</head>
<body>

<!-- Hero Section -->
<div class="hero">
<div class="container">
<div class="hero-b">AI Video Generation</div>
<h1>Flint Video Gen</h1>
<p>A text-to-video and image-to-video generation interface built with A2UI components. Create, edit, and manage AI-generated video content with real-time previews and batch processing.</p>
<div style="display:flex;gap:16px;justify-content:center;flex-wrap:wrap;margin-top:24px;">
<a href="FLINT-A2UI-REGISTRY-SPEC.html" class="btn btn-ghost">← Registry Spec</a>
<a href="FLINT-A2UI-DOCS.html" class="btn btn-ghost">← Docs</a>
<a href="FLINT-A2UI-CRM.html" class="btn btn-s">CRM →</a>
<a href="FLINT-A2UI-ERP.html" class="btn btn-s">ERP →</a>
</div>
</div>
</div>

<!-- Page Layout -->
<div class="page">
<!-- Sidebar Navigation -->
<nav class="snav">
<div class="snav-h">
<div class="snav-l"><div class="snav-li">F</div><span>Video Gen</span></div>
</div>
<div style="padding:12px 0;">
<a href="#generate" class="snav-i on">🎬 Generate</a>
<a href="#library" class="snav-i">📚 Library</a>
<a href="#batch" class="snav-i">⚡ Batch</a>
<a href="#settings" class="snav-i">⚙️ Settings</a>
</div>
</nav>

<!-- Main Content -->
<main class="main">
<div class="container">

<!-- Generate Section -->
<section id="generate" class="sec">
<div class="sec-h"><div class="icon">🎬</div><h3>Generate Video</h3><span class="tag">Text-to-Video</span></div>

<div class="comp-grid">
<div class="comp-item" style="grid-column:1/-1;">
<h4>🎬 Video Generation Prompt</h4>
<div class="demo">
<div class="demo-label">Prompt Interface</div>
<div class="fg">
<label class="lbl">Prompt</label>
<textarea class="tx vg-prompt" rows="4" placeholder="Describe the video you want to generate...">A cinematic aerial view of a futuristic city at sunset, neon lights reflecting on wet streets, flying vehicles, cyberpunk atmosphere, 4K quality, smooth camera movement</textarea>
</div>
<div class="vg-opts" style="margin-top:16px;">
<div class="vg-opt on"><div class="vg-opt-t">Cinematic</div><div class="vg-opt-d">High quality film look</div></div>
<div class="vg-opt"><div class="vg-opt-t">Anime</div><div class="vg-opt-d">Japanese animation style</div></div>
<div class="vg-opt"><div class="vg-opt-t">Realistic</div><div class="vg-opt-d">Photorealistic rendering</div></div>
<div class="vg-opt"><div class="vg-opt-t">3D Render</div><div class="vg-opt-d">Computer generated 3D</div></div>
<div class="vg-opt"><div class="vg-opt-t">Documentary</div><div class="vg-opt-d">Naturalistic style</div></div>
<div class="vg-opt"><div class="vg-opt-t">Abstract</div><div class="vg-opt-d">Experimental visuals</div></div>
</div>
<div class="grid grid-2" style="gap:12px;margin-top:16px;">
<div class="fg">
<label class="lbl">Duration</label>
<select class="sel">
<option>5 seconds</option><option selected>10 seconds</option><option>15 seconds</option><option>30 seconds</option><option>60 seconds</option>
</select>
</div>
<div class="fg">
<label class="lbl">Resolution</label>
<select class="sel">
<option>720p</option><option selected>1080p</option><option>4K</option><option>8K</option>
</select>
</div>
</div>
<div class="grid grid-2" style="gap:12px;margin-top:16px;">
<div class="fg">
<label class="lbl">Aspect Ratio</label>
<select class="sel">
<option>16:9 (Landscape)</option><option selected>16:9 (Landscape)</option><option>9:16 (Portrait)</option><option>1:1 (Square)</option><option>21:9 (Cinematic)</option>
</select>
</div>
<div class="fg">
<label class="lbl">Motion Style</label>
<select class="sel">
<option>Smooth</option><option selected>Dynamic</option><option>Static</option><option>Handheld</option>
</select>
</div>
</div>
<div class="fg" x-data="{seed:42}" style="margin-top:16px;">
<label class="lbl">Seed: <span x-text="seed"></span></label>
<input type="range" class="rng" min="0" max="1000" x-model="seed" style="width:100%;">
</div>
<div style="display:flex;gap:12px;margin-top:24px;align-items:center;">
<button class="btn btn-p btn-lg" style="flex:1;" hx-post="/api/video/generate" hx-target="#gen-result" hx-indicator="#gen-indicator">Generate Video</button>
<button class="btn btn-s">🎲 Randomize</button>
<button class="btn btn-ghost">📤 Import Image</button>
</div>
<div id="gen-indicator" class="htmx-indicator" style="margin-top:16px;">
<div class="vg-gen-st">
<div class="vg-gen-st-i" style="background:rgba(255,106,61,0.15);color:var(--em);">⟳</div>
<div style="flex:1;">
<div class="vg-gen-st-t">Generating video...</div>
<div class="vg-gen-st-d">This may take 2-5 minutes depending on length and resolution</div>
<div class="pf" style="margin-top:8px;"><span class="pf-l">Progress</span><div class="pf-b"><div class="pb"><div class="pb-b" style="width:45%"></div></div></div><span class="pf-v">45%</span></div>
</div>
</div>
</div>
<div id="gen-result" style="margin-top:16px;"></div>
</div>
<div class="demo-code">{"type":"video_generator","prompt":"A cinematic aerial view...","style":"cinematic","duration":"10s","resolution":"1080p","hx_post":"/api/video/generate"}</div>
</div>
</div>
</div>
</section>

<!-- Preview Section -->
<section class="sec">
<div class="sec-h"><div class="icon">▶️</div><h3>Preview</h3><span class="tag">Player</span></div>

<div class="comp-grid">
<div class="comp-item" style="grid-column:1/-1;">
<h4>🎬 Video Preview</h4>
<div class="demo">
<div class="demo-label">Generated Video</div>
<div class="vg-prev">
<div class="vg-prev-pl">🎬</div>
<div class="vg-prev-b">
<button class="vg-prev-btn">▶</button>
<div class="vg-prev-bar"><div class="vg-prev-bar-f" style="width:35%"></div></div>
<div class="vg-prev-ct">03:30 / 10:00</div>
<button class="vg-prev-btn">⚙</button>
<button class="vg-prev-btn">⛶</button>
</div>
</div>
<div style="display:flex;gap:12px;margin-top:16px;flex-wrap:wrap;">
<button class="btn btn-p">⬇️ Download</button>
<button class="btn btn-s">🎞️ Export Frames</button>
<button class="btn btn-s">🔄 Regenerate</button>
<button class="btn btn-ghost">🗑️ Delete</button>
</div>
</div>
<div class="demo-code">{"type":"video_preview","src":"/generated/video_001.mp4","duration":"10s","controls":true}</div>
</div>
</div>
</div>
</section>

<!-- Library Section -->
<section id="library" class="sec">
<div class="sec-h"><div class="icon">📚</div><h3>Video Library</h3><span class="tag">Collection</span></div>

<div class="comp-grid">
<div class="comp-item" style="grid-column:1/-1;">
<h4>📚 Generated Videos</h4>
<div class="demo">
<div class="demo-label">Video Collection</div>
<div class="fb">
<div class="ft"><input type="text" class="ft-i" placeholder="Search videos..."></div>
<select class="sel" style="width:150px;"><option>All Styles</option><option>Cinematic</option><option>Anime</option><option>Realistic</option></select>
<select class="sel" style="width:150px;"><option>All Durations</option><option>5s</option><option>10s</option><option>30s</option></select>
<button class="btn btn-s">Filter</button>
</div>
<div class="vg-thumb">
<div class="vg-thumb-i"><div style="width:100%;height:100%;display:flex;align-items:center;justify-content:center;font-size:32px;background:var(--s3);">🎬</div><div class="vg-thumb-i-d">Cyberpunk City</div><div class="vg-thumb-i-o"><button class="vg-prev-btn">▶</button></div></div>
<div class="vg-thumb-i"><div style="width:100%;height:100%;display:flex;align-items:center;justify-content:center;font-size:32px;background:var(--s3);">🎬</div><div class="vg-thumb-i-d">Ocean Waves</div><div class="vg-thumb-i-o"><button class="vg-prev-btn">▶</button></div></div>
<div class="vg-thumb-i"><div style="width:100%;height:100%;display:flex;align-items:center;justify-content:center;font-size:32px;background:var(--s3);">🎬</div><div class="vg-thumb-i-d">Space Station</div><div class="vg-thumb-i-o"><button class="vg-prev-btn">▶</button></div></div>
<div class="vg-thumb-i"><div style="width:100%;height:100%;display:flex;align-items:center;justify-content:center;font-size:32px;background:var(--s3);">🎬</div><div class="vg-thumb-i-d">Forest Path</div><div class="vg-thumb-i-o"><button class="vg-prev-btn">▶</button></div></div>
<div class="vg-thumb-i"><div style="width:100%;height:100%;display:flex;align-items:center;justify-content:center;font-size:32px;background:var(--s3);">🎬</div><div class="vg-thumb-i-d">Neon Streets</div><div class="vg-thumb-i-o"><button class="vg-prev-btn">▶</button></div></div>
<div class="vg-thumb-i"><div style="width:100%;height:100%;display:flex;align-items:center;justify-content:center;font-size:32px;background:var(--s3);">🎬</div><div class="vg-thumb-i-d">Mountain Lake</div><div class="vg-thumb-i-o"><button class="vg-prev-btn">▶</button></div></div>
</div>
<div class="pg" style="margin-top:16px;">
<button class="pg-b" disabled>‹ Prev</button>
<button class="pg-b on">1</button>
<button class="pg-b">2</button>
<button class="pg-b">3</button>
<button class="pg-b">Next ›</button>
</div>
</div>
<div class="demo-code">{"type":"video_library","videos":[...],"filters":["style","duration","resolution"],"hx_get":"/api/videos"}</div>
</div>
</div>
</div>
</section>

<!-- Batch Section -->
<section id="batch" class="sec">
<div class="sec-h"><div class="icon">⚡</div><h3>Batch Generation</h3><span class="tag">Bulk</span></div>

<div class="comp-grid">
<div class="comp-item" style="grid-column:1/-1;">
<h4>⚡ Batch Video Generation</h4>
<div class="demo">
<div class="demo-label">Bulk Processing</div>
<div class="fg">
<label class="lbl">Prompts (one per line)</label>
<textarea class="tx" rows="6" placeholder="Enter multiple prompts, one per line...">A serene Japanese garden with cherry blossoms
A futuristic cityscape with holographic billboards
An underwater coral reef with bioluminescent creatures
A volcanic eruption at night with lava flows
A medieval castle in the Scottish highlands</textarea>
</div>
<div class="grid grid-3" style="gap:12px;margin-top:16px;">
<div class="fg">
<label class="lbl">Duration</label>
<select class="sel"><option>5s</option><option selected>10s</option><option>15s</option></select>
</div>
<div class="fg">
<label class="lbl">Resolution</label>
<select class="sel"><option>720p</option><option selected>1080p</option></select>
</div>
<div class="fg">
<label class="lbl">Style</label>
<select class="sel"><option selected>Cinematic</option><option>Anime</option><option>Realistic</option></select>
</div>
</div>
<div style="display:flex;justify-content:space-between;align-items:center;margin-top:16px;">
<div style="font-size:13px;color:var(--txtd);">5 videos • ~25 min total</div>
<div style="display:flex;gap:8px;">
<button class="btn btn-ghost">Clear All</button>
<button class="btn btn-p" hx-post="/api/video/batch" hx-target="#batch-result">Start Batch</button>
</div>
</div>
<div id="batch-result" style="margin-top:16px;">
<div class="lst">
<div class="lst-i"><div class="lst-i-c"><div class="lst-i-t">A serene Japanese garden...</div><div class="lst-i-d">Queued</div></div><span class="bd-d">Waiting</span></div>
<div class="lst-i"><div class="lst-i-c"><div class="lst-i-t">A futuristic cityscape...</div><div class="lst-i-d">Queued</div></div><span class="bd-d">Waiting</span></div>
<div class="lst-i"><div class="lst-i-c"><div class="lst-i-t">An underwater coral reef...</div><div class="lst-i-d">Queued</div></div><span class="bd-d">Waiting</span></div>
<div class="lst-i"><div class="lst-i-c"><div class="lst-i-t">A volcanic eruption...</div><div class="lst-i-d">Queued</div></div><span class="bd-d">Waiting</span></div>
<div class="lst-i"><div class="lst-i-c"><div class="lst-i-t">A medieval castle...</div><div class="lst-i-d">Queued</div></div><span class="bd-d">Waiting</span></div>
</div>
</div>
</div>
<div class="demo-code">{"type":"batch_generator","prompts":["...","..."],"style":"cinematic","duration":"10s","hx_post":"/api/video/batch"}</div>
</div>
</div>
</div>
</section>

</div></main></div>
</body></html>
