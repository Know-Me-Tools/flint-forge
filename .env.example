# .env.example — all environment variables read by flint-forge services
#
# Copy to .env and fill in secrets before starting:
#   cp .env.example .env
#
# Keys marked REQUIRED must be set; all others have usable defaults.

# ── Database ──────────────────────────────────────────────────────────────────
# Connection string used by fdb-gateway and fke-server.
# When using docker compose the hostname is "db" (the service name).
# In production: scripts/rotate_secrets.sh updates this with a randomly generated
# password that matches secrets/postgres_password.txt.
# MANAGED VIA DOCKER SECRET (postgres_password) — see scripts/rotate_secrets.sh
DATABASE_URL=postgres://flint:flint@db:5432/flint

# ── Authentication ────────────────────────────────────────────────────────────
# REQUIRED: secret key for JWT signing. Generate with:
#   openssl rand -hex 32
# In production: MANAGED VIA DOCKER SECRET (jwt_secret) — see scripts/rotate_secrets.sh
# The secret file is mounted at /run/secrets/jwt_secret inside the container.
FLINT_JWT_SECRET=change-me-in-production

# ── Identity / Gate JWT validation (forge-identity crate) ────────────────────
# JWKS endpoint for verifying inbound JWTs.
# REQUIRED when JWT validation is enabled.
# FLINT_GATE_JWKS_URL=https://gate.example.com/.well-known/jwks.json

# Expected `iss` claim in inbound JWTs.
# REQUIRED when JWT validation is enabled.
# FLINT_GATE_ISSUER=https://gate.example.com

# Expected `aud` claim; validation skipped if not set.
# FLINT_GATE_AUDIENCE=

# Internal gate base URL (used by the flint_llm pgrx extension).
# FLINT_GATE_URL=http://fdb-gateway:8080

# ── Kiln Runtime ──────────────────────────────────────────────────────────────
# Epoch ticker interval in milliseconds (fke-runtime).
KILN_EPOCH_INTERVAL_MS=10

# ── Rate Limiting ─────────────────────────────────────────────────────────────
FLINT_RATE_LIMIT_REST=100
FLINT_RATE_LIMIT_GRAPHQL=20
FLINT_RATE_LIMIT_BURST=10

# ── DID Resolver ──────────────────────────────────────────────────────────────
FLINT_DID_RESOLVER_URL=https://did.flint.example.com

# ── Cosign / Sigstore ─────────────────────────────────────────────────────────
# Rekor transparency log endpoint.
FLINT_REKOR_URL=https://rekor.sigstore.dev

# Cosign verification mode: "full" (default) or "legacy" (raw SEC1 keys).
# FLINT_COSIGN_MODE=full

# ── Realtime change source (fdb-gateway) ─────────────────────────────────────
# Set to "listen" to use PostgreSQL LISTEN/NOTIFY instead of polling.
# FLINT_CHANGE_SOURCE=listen

# Broadcast channel capacity when FLINT_CHANGE_SOURCE=listen.
# FLINT_LISTEN_CAPACITY=1024

# ── Flint Realtime Fabric (FRF) endpoint ─────────────────────────────────────
# Connect-RPC endpoint for the FRF spine.
# FRF_ENDPOINT=http://frf:50051

# ── Keto (authorization) ─────────────────────────────────────────────────────
# ORY Keto read API base URL.
# KETO_BASE_URL=http://keto:4466

# Interval (seconds) between Keto sync sweeps.
# KETO_SYNC_INTERVAL_SECS=30

# ── Vault / Encryption ────────────────────────────────────────────────────────
# Base64-encoded wrapped data-encryption key (ext-flint-vault).
# FLINT_VAULT_DEK_WRAPPED=

# Path to a file containing the wrapped DEK.
# FLINT_VAULT_DEK_WRAPPED_FILE=

# Base64-encoded root key (used only if no unwrap command is configured).
# FLINT_VAULT_ROOT_KEY=

# Path to a file containing the root key.
# FLINT_VAULT_ROOT_KEY_FILE=

# Shell command that reads the wrapped DEK and writes the unwrapped key to stdout.
# Example: FLINT_VAULT_UNWRAP_CMD=vault kv get -field=key secret/flint/dek
# FLINT_VAULT_UNWRAP_CMD=

# ── Observability (optional) ──────────────────────────────────────────────────
# OpenTelemetry collector endpoint.
# OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317

# Structured log filter (tokio-tracing / env_logger syntax).
# RUST_LOG=info

# ── IPFS (optional) ───────────────────────────────────────────────────────────
# Kubo API endpoint used by fke-store-ipfs.
# FLINT_IPFS_URL=http://localhost:5001

# Kiln guest ABI version (informational; used by skill manifests).
FLINT_KILN_ABI_VERSION=1

# ── TLS / Caddy (production only) ────────────────────────────────────────────
# Required when using docker-compose.prod.yml.
# Caddy uses FLINT_DOMAIN to provision a Let's Encrypt TLS certificate.
# Both variables must be set; the prod compose file will refuse to start without them.
#
# FLINT_DOMAIN=forge.example.com
# CADDY_TLS_EMAIL=ops@example.com

# ── wal-g backups (production only) — p16-c008 ───────────────────────────────
# Optional: continuous WAL archiving + scheduled base backups for PITR.
# Absent/unset by default — the `db` and `backup` services both no-op cleanly
# without these (see docs/runbook.md §13.4/§14 for setup + the restore drill).
# Credentials themselves go in secrets/walg_s3_access_key.txt and
# secrets/walg_s3_secret_key.txt (via `WALG_S3_ACCESS_KEY`/`WALG_S3_SECRET_KEY`
# env vars passed to scripts/rotate_secrets.sh), never in this file.
#
# WALG_S3_PREFIX=s3://your-backup-bucket/flint-forge
# WALG_AWS_REGION=us-east-1
# WALG_BACKUP_INTERVAL_SECS=86400

# A2UI API version (informational; used by SDK clients to confirm compatibility).
FLINT_A2UI_API_VERSION=1

# ── Alertmanager (production only) ───────────────────────────────────────────
# Webhook URL for alert delivery (Slack, PagerDuty, generic HTTP endpoint).
# Uncomment and set in observability/alertmanager.yml to activate notifications.
# See docs/runbook.md §10 for configuration examples.
#
# ALERTMANAGER_WEBHOOK_URL=https://hooks.slack.com/services/T.../B.../...
